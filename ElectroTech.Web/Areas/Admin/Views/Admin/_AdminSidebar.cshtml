@{
    var ctrl = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var action = ViewContext.RouteData.Values["action"]?.ToString() ?? "";

    string IsActive(string controller) =>
        ctrl.Equals(controller, StringComparison.OrdinalIgnoreCase)
            ? "menu-item-active" : "menu-item-inactive";

    string IconActive(string controller) =>
        ctrl.Equals(controller, StringComparison.OrdinalIgnoreCase)
            ? "menu-item-icon-active" : "menu-item-icon-inactive";

    string DropActive(params string[] controllers) =>
        controllers.Any(c => ctrl.Equals(c, StringComparison.OrdinalIgnoreCase))
            ? "menu-item-active" : "menu-item-inactive";

    string DropIconActive(params string[] controllers) =>
        controllers.Any(c => ctrl.Equals(c, StringComparison.OrdinalIgnoreCase))
            ? "menu-item-icon-active" : "menu-item-icon-inactive";

    // ✅ Fix: SubActive kiểm tra cả controller lẫn action
    string SubActive(string controller, string act = "Index") =>
        ctrl.Equals(controller, StringComparison.OrdinalIgnoreCase)
        && action.Equals(act, StringComparison.OrdinalIgnoreCase)
            ? "menu-dropdown-item-active" : "menu-dropdown-item-inactive";

    bool IsOpen(params string[] controllers) =>
        controllers.Any(c => ctrl.Equals(c, StringComparison.OrdinalIgnoreCase));
}

<style>
    .menu-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 12px;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 500;
        color: #6b7280;
        cursor: pointer;
        transition: all 0.15s;
        position: relative;
        text-decoration: none;
        width: 100%;
    }

        .menu-item:hover {
            background: #f3f4f6;
            color: #111827;
        }

    .menu-item-active {
        background: #eff6ff !important;
        color: #3b82f6 !important;
        font-weight: 600;
    }

    .menu-item-inactive {
        color: #6b7280;
    }

    .menu-item-icon-active {
        color: #3b82f6 !important;
        fill: #3b82f6 !important;
    }

    .menu-item-icon-inactive {
        color: #9ca3af;
        fill: #9ca3af;
    }

    .menu-item-text {
        flex: 1;
    }

    .menu-item-arrow {
        transition: transform 0.2s;
        flex-shrink: 0;
    }

    .menu-item-arrow-active {
        transform: rotate(180deg);
        stroke: #3b82f6 !important;
    }

    .menu-item-arrow-inactive {
        stroke: #9ca3af;
    }

    .menu-dropdown {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .menu-dropdown-item {
        display: block;
        padding: 8px 12px;
        border-radius: 6px;
        font-size: 13px;
        font-weight: 500;
        color: #6b7280;
        text-decoration: none;
        transition: all 0.15s;
        position: relative;
    }

        .menu-dropdown-item:hover {
            background: #f3f4f6;
            color: #111827;
        }

    .menu-dropdown-item-active {
        background: #eff6ff !important;
        color: #3b82f6 !important;
        font-weight: 600;
    }

    .menu-dropdown-item-inactive {
        color: #6b7280;
    }

    .menu-group-title {
        color: #9ca3af;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.08em;
    }
</style>

<aside x-data="{ sidebarToggle: false }"
       :class="sidebarToggle ? 'translate-x-0 lg:w-[90px]' : '-translate-x-full'"
       class="sidebar fixed left-0 top-0 z-[9999] flex h-screen w-[290px] flex-col
              overflow-y-hidden border-r border-gray-200 bg-white px-5 duration-300
              ease-linear dark:border-gray-800 dark:bg-gray-900 lg:static lg:translate-x-0"
       @@click.outside="sidebarToggle = false">

    <!-- Header -->
    <div :class="sidebarToggle ? 'justify-center' : 'justify-between'"
         class="flex items-center gap-2 pb-7 pt-8">
        <a href="@Url.Action("Index", "Dashboard", new { area = "Admin" })">
            <span :class="sidebarToggle ? 'hidden' : ''"
                  class="text-xl font-black tracking-tighter text-blue-400">ElectroTech</span>
            <span :class="sidebarToggle ? 'lg:block' : 'hidden'"
                  class="text-xl font-black text-blue-400">E</span>
        </a>
        <button @@click="sidebarToggle = !sidebarToggle"
                :class="sidebarToggle ? 'hidden' : ''"
                class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-200 lg:block hidden">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M3 12h18M3 6h18M3 18h18" />
            </svg>
        </button>
    </div>

    <div class="no-scrollbar flex flex-col overflow-y-auto duration-300 ease-linear">
        <nav x-data="{
            open: '@(
                IsOpen("Dashboard")             ? "Dashboard" :
                IsOpen("Product","Category")   ? "Products"  :
                IsOpen("Orders")                ? "Orders"    :
                IsOpen("Users")                 ? "Users"     : ""
