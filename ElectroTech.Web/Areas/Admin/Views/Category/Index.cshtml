@model List<Entities.Categories>
@{
    ViewData["Title"] = "Quản lý danh mục";
    Layout = "~/Areas/Admin/Views/Admin/_LayoutAdmin.cshtml";
}

<div class="space-y-6">

    <!-- Header -->
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-black text-slate-900 tracking-tight">Danh mục</h1>
            <p class="text-sm text-slate-500 mt-1">
                Quản lý danh mục sản phẩm
                @if (Model != null)
                {
                    <span class="ml-1 text-slate-400">(@Model.Count danh mục)</span>
                }
            </p>
        </div>
        <a href="/Admin/Category/Create"
           class="inline-flex items-center gap-2 px-5 py-2.5 bg-blue-600 hover:bg-blue-500
                  text-white font-bold text-sm rounded-xl transition-colors">
            <span class="text-lg leading-none">+</span>
            Thêm danh mục
        </a>
    </div>

    <!-- Table card -->
    <div class="bg-white border border-slate-200 rounded-2xl overflow-hidden shadow-sm">

        @if (Model != null && Model.Any())
        {
            <!-- Table header -->
            <div class="grid grid-cols-12 gap-4 px-6 py-3 bg-slate-50 border-b border-slate-100">
                <div class="col-span-4 text-xs font-bold text-slate-400 uppercase tracking-wider">
                    Danh mục
                </div>
                <div class="col-span-3 text-xs font-bold text-slate-400 uppercase tracking-wider">
                    Mô tả
                </div>
                <div class="col-span-1 text-xs font-bold text-slate-400 uppercase tracking-wider text-center">
                    Thứ tự
                </div>
                <div class="col-span-2 text-xs font-bold text-slate-400 uppercase tracking-wider text-center">
                    Trạng thái
                </div>
                <div class="col-span-2 text-xs font-bold text-slate-400 uppercase tracking-wider text-right">
                    Thao tác
                </div>
            </div>

            <!-- Rows -->
            @foreach (var cat in Model)
            {
                <div class="grid grid-cols-12 gap-4 px-6 py-4 items-center
                            border-b border-slate-50 hover:bg-slate-50/60 transition-colors">

                    <!-- Name + image -->
                    <div class="col-span-4 flex items-center gap-3">
                        @if (!string.IsNullOrEmpty(cat.ImageUrl))
                        {
                            <img src="@cat.ImageUrl" alt="@cat.Name"
                                 class="w-11 h-11 rounded-xl object-cover border border-slate-100 flex-shrink-0" />
                        }
                        else
                        {
                            <div class="w-11 h-11 rounded-xl bg-slate-100 flex items-center
                                        justify-center flex-shrink-0 text-xl">
                                📁
                            </div>
                        }
                        <div class="min-w-0">
                            <p class="font-semibold text-slate-900 text-sm truncate">@cat.Name</p>
                            <p class="text-xs text-slate-400 font-mono truncate">/@cat.Slug</p>
                        </div>
                    </div>

                    <!-- Description -->
                    <div class="col-span-3">
                        <p class="text-sm text-slate-500 truncate">@(cat.Description ?? "—")</p>
                    </div>

                    <!-- Order -->
                    <div class="col-span-1 text-center">
                        <span class="inline-flex items-center justify-center w-7 h-7 rounded-lg
                                     bg-slate-100 text-slate-600 text-xs font-bold font-mono">
                            @cat.DisplayOrder
                        </span>
                    </div>

                    <!-- Status -->
                    <div class="col-span-2 flex justify-center">
                        @if (cat.IsActive)
                        {
                            <span class="inline-flex items-center gap-1.5 px-2.5 py-1
                                         bg-green-50 text-green-700 text-xs font-bold rounded-full
                                         border border-green-100">
                                <span class="w-1.5 h-1.5 bg-green-500 rounded-full"></span>
                                Hoạt động
                            </span>
                        }
                        else
                        {
                            <span class="inline-flex items-center gap-1.5 px-2.5 py-1
                                         bg-slate-100 text-slate-500 text-xs font-bold rounded-full
                                         border border-slate-200">
                                <span class="w-1.5 h-1.5 bg-slate-400 rounded-full"></span>
                                Ẩn
                            </span>
                        }
                    </div>

                    <!-- Actions -->
                    <div class="col-span-2 flex items-center justify-end gap-2">
                        <a href="/Admin/Category/Edit/@cat.Id"
                           class="inline-flex items-center gap-1 px-3 py-1.5 bg-blue-50
                                  hover:bg-blue-100 text-blue-600 text-xs font-bold
                                  rounded-lg transition-colors">
                            <span class="text-sm">✏️</span> Sửa
                        </a>
                        <form action="/Admin/Category/Delete" method="post"
                              onsubmit="return confirm('Xóa danh mục này?')"
                              class="inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@cat.Id" />
                            <button type="submit"
                                    class="inline-flex items-center gap-1 px-3 py-1.5
                                           bg-red-50 hover:bg-red-100 text-red-500
                                           text-xs font-bold rounded-lg transition-colors
                                           border-none cursor-pointer">
                                <span class="text-sm">🗑️</span> Xóa
                            </button>
                        </form>
                    </div>
                </div>
            }

            <!-- Footer count -->
            <div class="px-6 py-3 bg-slate-50 border-t border-slate-100">
                <p class="text-xs text-slate-400">
                    Tổng <span class="font-bold text-slate-600">@Model.Count</span> danh mục
                </p>
            </div>
        }
        else
        {
            <div class="flex flex-col items-center justify-center py-24 text-slate-400">
                <div class="w-16 h-16 bg-slate-100 rounded-2xl flex items-center
                            justify-center text-3xl mb-4">
                    📁
                </div>
                <p class="font-semibold text-slate-600 mb-1">Chưa có danh mục nào</p>
                <p class="text-sm text-slate-400 mb-6">Tạo danh mục đầu tiên để bắt đầu</p>
                <a href="/Admin/Category/Create"
                   class="inline-flex items-center gap-2 px-5 py-2.5 bg-blue-600
                          hover:bg-blue-500 text-white font-bold text-sm rounded-xl
                          transition-colors">
                    + Tạo danh mục đầu tiên
                </a>
            </div>
        }
    </div>
</div>
