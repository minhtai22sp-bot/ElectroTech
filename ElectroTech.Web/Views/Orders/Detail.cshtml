@using Entities
@using Enums
@model Order
@{
    ViewData["Title"] = $"Đơn hàng #{Model.OrderCode}";

    var (statusCls, statusLabel) = Model.Status switch
    {
        OrderStatus.Pending => ("bg-amber-400/10 text-amber-400 border-amber-400/25", "⏳ Chờ xác nhận"),
        OrderStatus.Confirmed => ("bg-blue-400/10 text-blue-400 border-blue-400/25", "✅ Đã xác nhận"),
        OrderStatus.Processing => ("bg-orange-400/10 text-orange-400 border-orange-400/25", "⚙️ Đang xử lý"),
        OrderStatus.Shipped => ("bg-violet-400/10 text-violet-400 border-violet-400/25", "🚚 Đang giao hàng"),
        OrderStatus.Delivered => ("bg-green-400/10 text-green-400 border-green-400/25", "📦 Đã giao hàng"),
        OrderStatus.Cancelled => ("bg-red-400/10 text-red-400 border-red-400/25", "❌ Đã hủy"),
        _ => ("bg-zinc-400/10 text-zinc-400 border-zinc-400/25", "Không xác định")
    };

    var paymentMethodLabel = Model.PaymentMethod switch
    {
        PaymentMethod.COD => "💵 Thanh toán khi nhận hàng (COD)",
        PaymentMethod.BankTransfer => "🏦 Chuyển khoản ngân hàng",
        PaymentMethod.VNPay => "📱 VNPay",
        PaymentMethod.MoMo => "🌸 MoMo",
        _ => Model.PaymentMethod.ToString()
    };
}

<main class="pt-24 pb-20 min-h-screen">
    <div class="max-w-4xl mx-auto px-6 md:px-8">

        <!-- Breadcrumb -->
        <nav class="flex items-center gap-1.5 mb-8 text-xs text-zinc-600">
            <a asp-controller="Orders" asp-action="Index"
               class="hover:text-[#adc7ff] transition-colors font-medium">
                Đơn hàng của tôi
            </a>
            <span class="material-symbols-outlined text-[14px]">chevron_right</span>
            <span class="text-zinc-400 font-bold">#@Model.OrderCode</span>
        </nav>

        <!-- Header -->
        <div class="flex items-start justify-between mb-10 flex-wrap gap-4">
            <div>
                <p class="text-[10px] font-bold uppercase tracking-[.25em] text-[#adc7ff] mb-2">
                    Chi tiết đơn hàng
                </p>
                <h1 class="text-3xl font-black text-white tracking-tight font-mono mb-1.5">
                    #@Model.OrderCode
                </h1>
                <p class="text-zinc-500 text-sm">
                    Đặt lúc @Model.CreatedOn.ToString("HH:mm") — @Model.CreatedOn.ToString("dd/MM/yyyy")
                </p>
            </div>
            <span class="px-4 py-2 rounded-full text-xs font-bold border @statusCls">
                @statusLabel
            </span>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-[1fr_300px] gap-5 items-start">

            <!-- ── LEFT ── -->
            <div class="flex flex-col gap-4">

                <!-- Sản phẩm đã đặt -->
                <div class="bg-[#16161a] rounded-2xl border border-white/[0.06] overflow-hidden">
                    <div class="px-6 py-4 border-b border-white/[0.05]">
                        <h2 class="text-sm font-bold text-white flex items-center gap-2">
                            <span class="material-symbols-outlined text-[#adc7ff]"
                                  style="font-size:18px;">shopping_bag</span>
                            Sản phẩm đã đặt
                            <span class="ml-1 text-[10px] font-bold text-zinc-600 bg-white/5
                                         px-2 py-0.5 rounded-full border border-white/[0.05]">
                                @(Model.OrderItems?.Count ?? 0) sản phẩm
                            </span>
                        </h2>
                    </div>
                    <div class="divide-y divide-white/[0.04]">
                        @foreach (var item in Model.OrderItems ?? new List<OrderItem>())
                        {
                            <div class="flex items-center gap-4 px-6 py-4">
                                <div class="w-14 h-14 rounded-xl overflow-hidden flex-shrink-0
                                            bg-[#0e0e0e] border border-white/[0.06]">
                                    @if (!string.IsNullOrEmpty(item.ProductImage))
                                    {
                                        <img src="@item.ProductImage" alt="@item.ProductName"
                                             class="w-full h-full object-cover" />
                                    }
                                    else
                                    {
                                        <div class="w-full h-full flex items-center justify-center">
                                            <span class="material-symbols-outlined text-zinc-700"
                                                  style="font-size:22px;">image_not_supported</span>
                                        </div>
                                    }
                                </div>
                                <div class="flex-1 min-w-0">
                                    <p class="font-bold text-white text-sm truncate">
                                        @item.ProductName
                                    </p>
                                    <p class="text-zinc-600 text-xs mt-0.5">
                                        @item.UnitPrice.ToString("N0")₫ × @item.Quantity
                                    </p>
                                </div>
                                <p class="font-extrabold text-white text-sm whitespace-nowrap">
                                    @item.TotalPrice.ToString("N0")₫
                                </p>
                            </div>
                        }
                    </div>
                </div>

                <!-- Thông tin giao hàng -->
                <div class="bg-[#16161a] rounded-2xl border border-white/[0.06] overflow-hidden">
                    <div class="px-6 py-4 border-b border-white/[0.05]">
                        <h2 class="text-sm font-bold text-white flex items-center gap-2">
                            <span class="material-symbols-outlined text-[#adc7ff]"
                                  style="font-size:18px;">local_shipping</span>
                            Thông tin giao hàng
                        </h2>
                    </div>
                    <div class="px-6 py-5 grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div>
                            <p class="text-[10px] font-bold uppercase tracking-widest text-zinc-600 mb-1">
                                Người nhận
                            </p>
                            <p class="text-sm font-semibold text-white">@(Model.FullName ?? "—")</p>
                        </div>
                        <div>
                            <p class="text-[10px] font-bold uppercase tracking-widest text-zinc-600 mb-1">
                                Số điện thoại
                            </p>
                            <p class="text-sm font-semibold text-white">@(Model.Phone ?? "—")</p>
                        </div>
                        <div>
                            <p class="text-[10px] font-bold uppercase tracking-widest text-zinc-600 mb-1">
                                Email
                            </p>
                            <p class="text-sm font-semibold text-white">@(Model.Email ?? "—")</p>
                        </div>
                        <div class="sm:col-span-2">
                            <p class="text-[10px] font-bold uppercase tracking-widest text-zinc-600 mb-1">
                                Địa chỉ giao hàng
                            </p>
                            <p class="text-sm font-semibold text-white">@(Model.ShippingAddress ?? "—")</p>
                        </div>
                        @if (!string.IsNullOrEmpty(Model.Note))
                        {
                            <div class="sm:col-span-2">
                                <p class="text-[10px] font-bold uppercase tracking-widest text-zinc-600 mb-1">
                                    Ghi chú
                                </p>
                                <p class="text-sm text-zinc-400">@Model.Note</p>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- ── RIGHT: Summary ── -->
            <div class="lg:sticky lg:top-24 flex flex-col gap-4">

                <!-- Tóm tắt -->
                <div class="bg-[#16161a] rounded-2xl border border-white/[0.06] overflow-hidden">
                    <div class="px-6 py-4 border-b border-white/[0.05]">
                        <h2 class="text-sm font-bold text-white flex items-center gap-2">
                            <span class="material-symbols-outlined text-[#adc7ff]"
                                  style="font-size:18px;">receipt_long</span>
                            Tóm tắt
                        </h2>
                    </div>
                    <div class="px-6 py-5 space-y-3 text-sm">
                        <div class="flex justify-between">
                            <span class="text-zinc-500">Tạm tính</span>
                            <span class="text-zinc-300 font-medium">@Model.SubTotal.ToString("N0")₫</span>
                        </div>
                        @if (Model.DiscountAmount > 0)
                        {
                            <div class="flex justify-between">
                                <span class="text-zinc-500">Giảm giá</span>
                                <span class="text-green-400 font-semibold">-@Model.DiscountAmount.ToString("N0")₫</span>
                            </div>
                        }
                        <div class="flex justify-between">
                            <span class="text-zinc-500">Vận chuyển</span>
                            <span class="text-green-400 font-semibold">
                                @(Model.ShippingFee == 0 ? "Miễn phí" : Model.ShippingFee.ToString("N0") + "₫")
                            </span>
                        </div>
                        <div class="h-px bg-white/[0.05] my-1"></div>
                        <div class="flex justify-between items-center pt-1">
                            <span class="font-bold text-white">Tổng cộng</span>
                            <span class="font-black text-xl text-[#adc7ff]">
                                @Model.TotalAmount.ToString("N0")₫
                            </span>
                        </div>
                    </div>
                </div>

                <!-- Thanh toán -->
                <div class="bg-[#16161a] rounded-2xl border border-white/[0.06] overflow-hidden">
                    <div class="px-6 py-4 border-b border-white/[0.05]">
                        <h2 class="text-sm font-bold text-white flex items-center gap-2">
                            <span class="material-symbols-outlined text-[#adc7ff]"
                                  style="font-size:18px;">credit_card</span>
                            Thanh toán
                        </h2>
                    </div>
                    <div class="px-6 py-5 space-y-3">
                        <div>
                            <p class="text-[10px] font-bold uppercase tracking-widest text-zinc-600 mb-1.5">
                                Phương thức
                            </p>
                            <p class="text-sm font-bold text-white">@paymentMethodLabel</p>
                        </div>
                        <div>
                            <p class="text-[10px] font-bold uppercase tracking-widest text-zinc-600 mb-1.5">
                                Trạng thái
                            </p>
                            @if (Model.PaymentStatus == PaymentStatus.Paid)
                            {
                                <span class="inline-flex items-center gap-1.5 text-xs font-bold
                                             text-green-400 bg-green-400/10 px-3 py-1.5
                                             rounded-full border border-green-400/20">
                                    <span class="material-symbols-outlined text-[13px]"
                                          style="font-variation-settings:'FILL' 1;">check_circle</span>
                                    Đã thanh toán
                                </span>
                            }
                            else if (Model.PaymentStatus == PaymentStatus.Refunded)
                            {
                                <span class="inline-flex items-center gap-1.5 text-xs font-bold
                                             text-violet-400 bg-violet-400/10 px-3 py-1.5
                                             rounded-full border border-violet-400/20">
                                    <span class="material-symbols-outlined text-[13px]">undo</span>
                                    Đã hoàn tiền
                                </span>
                            }
                            else
                            {
                                <span class="inline-flex items-center gap-1.5 text-xs font-bold
                                             text-amber-400 bg-amber-400/10 px-3 py-1.5
                                             rounded-full border border-amber-400/20">
                                    <span class="material-symbols-outlined text-[13px]">schedule</span>
                                    Chưa thanh toán
                                </span>
                            }
                        </div>
                    </div>
                </div>

                <!-- Back -->
                <a asp-controller="Orders" asp-action="Index"
                   class="flex items-center justify-center gap-2 w-full py-3
                          bg-white/5 border border-white/[0.07]
                          hover:bg-white/[0.08] hover:border-white/[0.12]
                          rounded-xl text-zinc-400 hover:text-white
                          transition-all text-xs font-semibold">
                    <span class="material-symbols-outlined text-[15px]">arrow_back</span>
                    Quay lại đơn hàng của tôi
                </a>
            </div>

        </div>
    </div>
</main>
