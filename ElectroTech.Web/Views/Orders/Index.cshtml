@using Entities
@using Enums
@model List<Order>
@{
    ViewData["Title"] = "Đơn hàng của tôi";

    var steps = new (OrderStatus Status, string Icon, string Label)[]
    {
        (OrderStatus.Pending,    "pending",        "Chờ xác nhận"),
        (OrderStatus.Confirmed,  "verified",       "Đã xác nhận"),
        (OrderStatus.Processing, "manufacturing",  "Đang xử lý"),
        (OrderStatus.Shipped,    "local_shipping", "Đang giao"),
        (OrderStatus.Delivered,  "inventory",      "Đã giao"),
    };

    int StepIndex(OrderStatus s) => s switch
    {
        OrderStatus.Pending => 0,
        OrderStatus.Confirmed => 1,
        OrderStatus.Processing => 2,
        OrderStatus.Shipped => 3,
        OrderStatus.Delivered => 4,
        _ => -1
    };

    var tabs = new (string Val, string Label, string Cls)[]
    {
        ("all",        "Tất cả",       ""),
        ("Pending",    "Chờ xác nhận", "amber"),
        ("Confirmed",  "Đã xác nhận",  "blue"),
        ("Processing", "Đang xử lý",   "orange"),
        ("Shipped",    "Đang giao",    "violet"),
        ("Delivered",  "Đã giao",      "green"),
        ("Cancelled",  "Đã hủy",       "red"),
    };

    int CountOf(string val) => val == "all"
        ? Model.Count
        : Model.Count(o => o.Status.ToString() == val);

    // Dynamic Razor classes — Tailwind CDN không scan được
}

<style>
    .tab-default {
        background: transparent;
        color: #6b7280;
        border-color: #e5e5e5;
    }

        .tab-default:hover {
            background: #f5f5f5;
            color: #111;
        }

    .tab-amber {
        background: rgba(251,191,36,.1);
        color: #d97706;
        border-color: rgba(251,191,36,.3);
    }

    .tab-blue {
        background: rgba(96,165,250,.1);
        color: #2563eb;
        border-color: rgba(96,165,250,.3);
    }

    .tab-orange {
        background: rgba(249,115,22,.1);
        color: #ea6c0a;
        border-color: rgba(249,115,22,.3);
    }

    .tab-violet {
        background: rgba(167,139,250,.1);
        color: #7c3aed;
        border-color: rgba(167,139,250,.3);
    }

    .tab-green {
        background: rgba(74,222,128,.1);
        color: #16a34a;
        border-color: rgba(74,222,128,.3);
    }

    .tab-red {
        background: rgba(248,113,113,.1);
        color: #dc2626;
        border-color: rgba(248,113,113,.3);
    }

    .tab-all {
        background: rgba(249,115,22,.1);
        color: #ea6c0a;
        border-color: rgba(249,115,22,.3);
    }

    .status-pending {
        background: rgba(251,191,36,.1);
        color: #d97706;
        border-color: rgba(251,191,36,.25);
    }

    .status-confirmed {
        background: rgba(96,165,250,.1);
        color: #2563eb;
        border-color: rgba(96,165,250,.25);
    }

    .status-processing {
        background: rgba(249,115,22,.1);
        color: #ea6c0a;
        border-color: rgba(249,115,22,.25);
    }

    .status-shipped {
        background: rgba(167,139,250,.1);
        color: #7c3aed;
        border-color: rgba(167,139,250,.25);
    }

    .status-delivered {
        background: rgba(74,222,128,.1);
        color: #16a34a;
        border-color: rgba(74,222,128,.25);
    }

    .status-cancelled {
        background: rgba(248,113,113,.1);
        color: #dc2626;
        border-color: rgba(248,113,113,.25);
    }
</style>

<div class="max-w-3xl mx-auto px-6 py-10">

    <!-- Header -->
    <div class="mb-8">
        <p class="text-[11px] font-bold uppercase tracking-[.25em] text-orange-500 mb-2">
            Tài khoản của bạn
        </p>
        <h1 class="text-3xl font-black text-[#111] tracking-tight mb-1">
            Đơn hàng của tôi
        </h1>
        <p class="text-gray-400 text-sm">@Model.Count đơn hàng</p>
    </div>

    <!-- Filter tabs -->
    <div class="flex gap-2 flex-wrap mb-6">
        @foreach (var tab in tabs)
        {
            var count = CountOf(tab.Val);
            if (count == 0 && tab.Val != "all") continue;

            var tabCls = "tab-" + (string.IsNullOrEmpty(tab.Cls) ? "all" : tab.Cls);

            <button onclick="filterOrders('@tab.Val')"
                    id="tab-@tab.Val"
                    data-tab-cls="@tabCls"
                    class="tab-btn tab-default inline-flex items-center gap-2 px-4 py-2 rounded-xl
                           text-xs font-bold border transition-all cursor-pointer">
                @tab.Label
                <span class="text-[10px] px-1.5 py-0.5 rounded-full bg-black/[0.06] font-bold min-w-[18px] text-center">
                    @count
                </span>
            </button>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="flex flex-col items-center justify-center py-24 text-center">
            <div class="w-20 h-20 rounded-2xl bg-gray-100 border border-gray-200
                        flex items-center justify-center mb-5">
                <span class="material-symbols-outlined text-gray-300" style="font-size:40px;">shopping_bag</span>
            </div>
            <p class="text-[#111] font-bold text-lg mb-2">Chưa có đơn hàng nào</p>
            <p class="text-gray-400 text-sm mb-6">Hãy khám phá các sản phẩm và đặt hàng ngay!</p>
            <a asp-controller="Products" asp-action="Index"
               class="inline-flex items-center gap-2 px-6 py-3 bg-orange-500 text-white
                      font-bold rounded-xl hover:bg-orange-600 transition-all text-sm no-underline
                      shadow-[0_4px_14px_rgba(249,115,22,.35)]">
                <span class="material-symbols-outlined" style="font-size:18px;">shopping_cart</span>
                Mua sắm ngay
            </a>
        </div>
    }
    else
    {
        <div id="emptyFilter" class="hidden flex-col items-center justify-center py-16 text-center">
            <span class="material-symbols-outlined text-gray-300 mb-3" style="font-size:44px;">filter_list_off</span>
            <p class="text-gray-400 text-sm">Không có đơn hàng nào trong mục này</p>
        </div>

        <div id="orderList" class="flex flex-col gap-4">
            @foreach (var order in Model.OrderByDescending(o => o.CreatedOn))
            {
                var statusCls = order.Status switch
                {
                    OrderStatus.Pending => "status-pending",
                    OrderStatus.Confirmed => "status-confirmed",
                    OrderStatus.Processing => "status-processing",
                    OrderStatus.Shipped => "status-shipped",
                    OrderStatus.Delivered => "status-delivered",
                    OrderStatus.Cancelled => "status-cancelled",
                    _ => "status-cancelled"
                };
                var statusLabel = order.Status switch
                {
                    OrderStatus.Pending => "⏳ Chờ xác nhận",
                    OrderStatus.Confirmed => "✅ Đã xác nhận",
                    OrderStatus.Processing => "⚙️ Đang xử lý",
                    OrderStatus.Shipped => "🚚 Đang giao",
                    OrderStatus.Delivered => "📦 Đã giao",
                    OrderStatus.Cancelled => "❌ Đã hủy",
                    _ => order.Status.ToString()
                };
                var paymentLabel = order.PaymentMethod switch
                {
                    PaymentMethod.COD => "COD",
                    PaymentMethod.BankTransfer => "Chuyển khoản",
                    PaymentMethod.VNPay => "VNPay",
                    PaymentMethod.MoMo => "MoMo",
                    _ => order.PaymentMethod.ToString()
                };
                var paymentIcon = order.PaymentMethod == PaymentMethod.COD ? "local_shipping" : "account_balance";
                var currentStep = StepIndex(order.Status);
                var isCancelled = order.Status == OrderStatus.Cancelled;
                var isDelivered = order.Status == OrderStatus.Delivered;
                var pct = currentStep > 0 ? (int)((double)currentStep / (steps.Length - 1) * 100) : 0;
                var reviewed = ViewBag.ReviewedProductIds as HashSet<int> ?? new HashSet<int>();

                <div class="order-card group bg-white rounded-2xl border border-gray-100
                            hover:border-orange-200 hover:-translate-y-0.5
                            hover:shadow-[0_8px_32px_rgba(0,0,0,.08)]
                            transition-all duration-200 overflow-hidden"
                     data-status="@order.Status.ToString()">

                    <div class="p-5">
                        <!-- Top row -->
                        <div class="flex justify-between items-start mb-4 gap-3 flex-wrap">
                            <div>
                                <p class="text-[10px] font-bold uppercase tracking-[.2em] text-gray-400 mb-1">Mã đơn hàng</p>
                                <p class="text-sm font-black text-[#111] font-mono tracking-tight">#@order.OrderCode</p>
                                <p class="text-[11px] text-gray-400 mt-0.5">@order.CreatedOn.ToString("HH:mm — dd/MM/yyyy")</p>
                            </div>
                            <span class="inline-flex items-center px-3 py-1.5 rounded-full text-[11px] font-bold border @statusCls">
                                @statusLabel
                            </span>
                        </div>

                        <!-- Progress Tracker -->
                        @if (!isCancelled)
                        {
                            <div class="mb-4">
                                <div class="relative flex items-start justify-between">
                                    <!-- Track bg -->
                                    <div class="absolute h-[2px] bg-gray-100"
                                         style="top:15px;left:10%;right:10%;"></div>
                                    <!-- Track fill -->
                                    <div class="absolute h-[2px] bg-gradient-to-r from-orange-400 to-orange-300 transition-all duration-700"
                                         style="top:15px;left:10%;width:calc(@(pct)% * 0.8);"></div>

                                    @for (int i = 0; i < steps.Length; i++)
                                    {
                                        var step = steps[i];
                                        var isDone = currentStep > i;
                                        var isCur = currentStep == i;
                                        var dotBg = isDone ? "background:#f97316;border-color:#f97316;"
                                        : isCur ? "background:#fff7ed;border-color:#f97316;box-shadow:0 0 10px rgba(249,115,22,.3);"
                                        : "background:#f9fafb;border-color:#e5e7eb;";
                                        var iconCl = isDone ? "#fff" : isCur ? "#f97316" : "#d1d5db";
                                        var lblCl = isDone ? "text-gray-400" : isCur ? "text-orange-500 font-bold" : "text-gray-300";
                                        var fillVal = isDone ? "1" : "0";

                                        <div class="relative flex flex-col items-center gap-1.5 z-10" style="width:20%">
                                            <div class="w-[30px] h-[30px] rounded-full border-2 flex items-center justify-center flex-shrink-0 transition-all duration-300"
                                                 style="@dotBg">
                                                <span class="material-symbols-outlined"
                                                      style="font-size:13px;color:@iconCl;font-variation-settings:'FILL' @fillVal;">
                                                    @(isDone ? "check" : step.Icon)
                                                </span>
                                            </div>
                                            <p class="text-[9px] text-center leading-tight @lblCl transition-colors">
                                                @step.Label
                                            </p>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="mb-4 flex items-center gap-2.5 px-4 py-3 bg-red-50 border border-red-100 rounded-xl">
                                <span class="material-symbols-outlined text-red-400" style="font-size:16px;">cancel</span>
                                <p class="text-xs text-red-500 font-semibold">Đơn hàng đã bị hủy</p>
                            </div>
                        }

                        <!-- Thumbnails -->
                        @if (order.OrderItems != null && order.OrderItems.Any())
                        {
                            <div class="flex gap-2 mb-4 flex-wrap">
                                @foreach (var item in order.OrderItems.Take(4))
                                {
                                    <div class="w-12 h-12 rounded-xl overflow-hidden flex-shrink-0 bg-gray-50 border border-gray-100">
                                        @if (!string.IsNullOrEmpty(item.ProductImage))
                                        {
                                            <img src="@item.ProductImage" alt="@item.ProductName" class="w-full h-full object-cover" />
                                        }
                                        else
                                        {
                                            <div class="w-full h-full flex items-center justify-center">
                                                <span class="material-symbols-outlined text-gray-300" style="font-size:18px;">inventory_2</span>
                                            </div>
                                        }
                                    </div>
                                }
                                @if (order.OrderItems.Count > 4)
                                {
                                    <div class="w-12 h-12 rounded-xl bg-gray-50 border border-gray-100 flex items-center justify-center flex-shrink-0">
                                        <span class="text-xs font-bold text-gray-400">+@(order.OrderItems.Count - 4)</span>
                                    </div>
                                }
                            </div>
                        }

                        <!-- Bottom row -->
                        <div class="flex justify-between items-center pt-3.5 border-t border-gray-50 flex-wrap gap-3">
                            <div class="flex items-center gap-3 text-[11px] text-gray-400">
                                <span class="flex items-center gap-1">
                                    <span class="material-symbols-outlined" style="font-size:13px;">@paymentIcon</span>
                                    @paymentLabel
                                </span>
                                <span class="w-px h-3 bg-gray-200"></span>
                                <span>@(order.OrderItems?.Count ?? 0) sản phẩm</span>
                            </div>

                            <div class="flex items-center gap-2 flex-wrap">
                                <span class="font-black text-lg text-[#111]">@order.TotalAmount.ToString("N0")₫</span>

                                <!-- Xem chi tiết -->
                                <a asp-controller="Orders" asp-action="Detail" asp-route-id="@order.Id"
                                   class="inline-flex items-center gap-1 px-3.5 py-2 rounded-xl text-xs font-bold
                                          bg-orange-50 border border-orange-100 text-orange-500
                                          hover:bg-orange-100 transition-all no-underline">
                                    Xem chi tiết
                                    <span class="material-symbols-outlined" style="font-size:13px;">arrow_forward</span>
                                </a>

                                <!-- Nút đánh giá / đã đánh giá -->
                                @if (isDelivered)
                                {
                                    @foreach (var orderItem in order.OrderItems ?? new List<OrderItem>())
                                    {
                                        var pid = orderItem.ProductId ?? 0;
                                        var alreadyReviewed = reviewed.Contains(pid);

                                        @if (alreadyReviewed)
                                        {
                                            <span class="inline-flex items-center gap-1 px-3.5 py-2 rounded-xl text-xs font-bold
                                                         bg-green-50 border border-green-100 text-green-600 cursor-default">
                                                <span class="material-symbols-outlined" style="font-size:13px;font-variation-settings:'FILL' 1;">check_circle</span>
                                                Đã đánh giá
                                            </span>
                                        }
                                        else
                                        {
                                            <a asp-controller="Products" asp-action="Detail"
                                               asp-route-id="@orderItem.ProductId"
                                               asp-route-orderId="@order.Id"
                                               class="inline-flex items-center gap-1 px-3.5 py-2 rounded-xl text-xs font-bold
                                                      bg-amber-50 border border-amber-100 text-amber-600
                                                      hover:bg-amber-100 transition-all no-underline"
                                               title="@orderItem.ProductName">
                                                <span class="material-symbols-outlined" style="font-size:13px;font-variation-settings:'FILL' 1;">star</span>
                                                Đánh giá
                                            </a>
                                        }
                                    }
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
    <script>
        // ── Tab filter ────────────────────────────────────────────────────
        function filterOrders(status) {
            // Reset tất cả tab về default
            document.querySelectorAll('.tab-btn').forEach(btn => {
                btn.classList.remove(
                    'tab-all', 'tab-amber', 'tab-blue', 'tab-orange',
                    'tab-violet', 'tab-green', 'tab-red'
                );
                btn.classList.add('tab-default');
            });

            // Active tab được chọn
            const active = document.getElementById('tab-' + status);
            if (active) {
                active.classList.remove('tab-default');
                active.classList.add(active.dataset.tabCls);
            }

            // Show/hide cards
            let visible = 0;
            document.querySelectorAll('.order-card').forEach(card => {
                const match = status === 'all' || card.dataset.status === status;
                card.style.display = match ? '' : 'none';
                if (match) visible++;
            });

            const empty = document.getElementById('emptyFilter');
            const list = document.getElementById('orderList');
            if (empty && list) {
                if (visible === 0) {
                    empty.classList.remove('hidden'); empty.classList.add('flex');
                    list.classList.add('hidden');
                } else {
                    empty.classList.add('hidden'); empty.classList.remove('flex');
                    list.classList.remove('hidden');
                }
            }
        }

        document.addEventListener('DOMContentLoaded', () => filterOrders('all'));
    </script>
}
