@using Entities.ViewModel
@model Library.PaginatedList<ProductIndexModel>

@{
    var categories = ViewBag.Categories as List<Entities.Categories> ?? new();
}

<style>
    :root {
        --bg: #efefed;
        --card: #ffffff;
        --orange: #f97316;
        --black: #111111;
        --muted: #6b7280;
        --border: #e2e2df;
    }

    .hp {
        background: var(--bg);
        min-height: 100vh;
        font-family: 'DM Sans',sans-serif;
        color: var(--black);
    }

    .wrap {
        max-width: 1280px;
        margin: 0 auto;
        padding: 0 40px;
    }

    /* Hero */
    .hero {
        display: grid;
        grid-template-columns: 1fr 1fr;
        align-items: center;
        gap: 0;
        padding: 48px 40px 40px;
        max-width: 1280px;
        margin: 0 auto;
    }

    .hero-eye {
        font-size: 10px;
        font-weight: 800;
        letter-spacing: .26em;
        text-transform: uppercase;
        color: var(--orange);
        margin: 0 0 12px;
    }

    .hero-h1 {
        font-family: 'Syne',sans-serif;
        font-size: clamp(2.2rem,3.8vw,3.8rem);
        font-weight: 900;
        line-height: .92;
        letter-spacing: -.03em;
        margin: 0 0 14px;
    }

        .hero-h1 .or {
            color: var(--orange);
            display: block;
        }

    .hero-desc {
        font-size: 13px;
        color: var(--muted);
        line-height: 1.65;
        max-width: 360px;
        margin: 0 0 24px;
    }

    .hero-btns {
        display: flex;
        gap: 10px;
    }

    .btn-ora {
        padding: 11px 22px;
        border-radius: 10px;
        background: var(--orange);
        color: #fff;
        font-weight: 800;
        font-size: 13px;
        text-decoration: none;
        transition: all .2s;
        box-shadow: 0 4px 14px rgba(249,115,22,.35);
    }

        .btn-ora:hover {
            background: #ea6c0a;
            transform: translateY(-2px);
        }

    .btn-out {
        padding: 10px 22px;
        border-radius: 10px;
        background: transparent;
        color: var(--black);
        font-weight: 700;
        font-size: 13px;
        text-decoration: none;
        border: 2px solid var(--black);
        transition: all .2s;
    }

        .btn-out:hover {
            background: var(--black);
            color: #fff;
        }

    .hero-imgbox {
        background: #e4e4e2;
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 36px 32px;
        aspect-ratio: 1.15/1;
        overflow: hidden;
        margin-left: 40px;
    }

        .hero-imgbox img {
            width: 100%;
            max-width: 340px;
            filter: drop-shadow(0 24px 40px rgba(0,0,0,.15));
            transition: transform .5s ease;
        }

        .hero-imgbox:hover img {
            transform: scale(1.04) translateY(-6px);
        }

    /* Section */
    .sec {
        padding: 0 40px 52px;
        max-width: 1280px;
        margin: 0 auto;
    }

    .sec-eye {
        font-size: 10px;
        font-weight: 800;
        letter-spacing: .26em;
        text-transform: uppercase;
        color: var(--orange);
        margin: 0 0 4px;
    }

    .sec-head {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        margin-bottom: 20px;
    }

    .sec-h2 {
        font-family: 'Syne',sans-serif;
        font-size: 1.6rem;
        font-weight: 900;
        letter-spacing: -.02em;
        margin: 0;
    }

    .sec-link {
        color: var(--orange);
        font-size: 12px;
        font-weight: 700;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 3px;
        white-space: nowrap;
        transition: gap .15s;
    }

        .sec-link:hover {
            gap: 7px;
        }

    /* Category */
    .cat-grid2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
    }

    .cat-grid3 {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: 12px;
    }

    .cat-card {
        position: relative;
        border-radius: 16px;
        overflow: hidden;
        display: block;
        text-decoration: none;
        aspect-ratio: 16/9;
        background: #222;
        transition: transform .25s cubic-bezier(.34,1.56,.64,1),box-shadow .25s;
    }

        .cat-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 16px 40px rgba(0,0,0,.16);
        }

        .cat-card img {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            opacity: .78;
            transition: transform .4s,opacity .3s;
        }

        .cat-card:hover img {
            transform: scale(1.05);
            opacity: .88;
        }

    .cat-ov {
        position: absolute;
        inset: 0;
        background: linear-gradient(to top,rgba(0,0,0,.82) 0%,rgba(0,0,0,.15) 55%,transparent 100%);
    }

    .cat-body {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        padding: 18px 22px;
    }

    .cat-eye {
        font-size: 9px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: .2em;
        color: var(--orange);
        margin: 0 0 5px;
    }

    .cat-name {
        font-family: 'Syne',sans-serif;
        font-size: 1.3rem;
        font-weight: 900;
        color: #fff;
        margin: 0 0 8px;
        letter-spacing: -.015em;
    }

    .cat-cta {
        display: inline-flex;
        align-items: center;
        gap: 3px;
        color: #fff;
        font-size: 11px;
        font-weight: 700;
    }

    /* Trending */
    .trend-head {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        margin-bottom: 20px;
        gap: 24px;
    }

    .trend-left .sec-h2 {
        font-size: 2rem;
    }

    .trend-desc {
        color: var(--muted);
        font-size: 12px;
        line-height: 1.6;
        max-width: 300px;
        margin: 6px 0 0;
    }

    .pills {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        align-items: center;
    }

    .pill {
        padding: 8px 16px;
        border-radius: 40px;
        font-size: 11px;
        font-weight: 700;
        cursor: pointer;
        text-decoration: none;
        transition: all .2s;
        white-space: nowrap;
    }

    .pill-a {
        background: var(--orange);
        color: #fff;
        box-shadow: 0 3px 12px rgba(249,115,22,.3);
    }

    .pill-i {
        background: var(--card);
        color: var(--black);
        border: 1.5px solid var(--border);
    }

        .pill-i:hover {
            border-color: #999;
        }

    /* Product grid — 4 cols compact */
    .prod-grid {
        display: grid;
        grid-template-columns: repeat(4,1fr);
        gap: 12px;
    }

    .prod-card {
        background: var(--card);
        border-radius: 14px;
        overflow: hidden;
        text-decoration: none;
        display: flex;
        flex-direction: column;
        border: 1.5px solid var(--border);
        transition: transform .2s ease,box-shadow .2s ease;
    }

        .prod-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 12px 32px rgba(0,0,0,.09);
        }

    .prod-img {
        position: relative;
        aspect-ratio: 1;
        overflow: hidden;
        background: #e8e8e6;
    }

        .prod-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform .4s;
        }

    .prod-card:hover .prod-img img {
        transform: scale(1.04);
    }

    .prod-badge {
        position: absolute;
        top: 10px;
        left: 10px;
        padding: 3px 10px;
        border-radius: 30px;
        font-size: 10px;
        font-weight: 800;
    }

    .b-new {
        background: var(--orange);
        color: #fff;
    }

    .b-pre {
        background: #3b82f6;
        color: #fff;
    }

    .b-sale {
        background: var(--black);
        color: #fff;
    }

    .b-sold {
        background: #e5e7eb;
        color: #6b7280;
    }

    .prod-body {
        padding: 12px 14px 14px;
        display: flex;
        flex-direction: column;
        gap: 3px;
        flex: 1;
    }

    .prod-brand {
        font-size: 10px;
        color: var(--muted);
        margin: 0;
    }

    .prod-name {
        font-family: 'Syne',sans-serif;
        font-size: .9rem;
        font-weight: 800;
        color: var(--orange);
        margin: 0 0 2px;
        line-height: 1.3;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .prod-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-top: auto;
        padding-top: 10px;
        border-top: 1.5px solid var(--border);
    }

    .prod-price {
        font-family: 'Syne',sans-serif;
        font-size: 1rem;
        font-weight: 900;
        color: var(--orange);
    }

    .prod-orig {
        font-size: 10px;
        color: #9ca3af;
        text-decoration: line-through;
        margin-top: 1px;
    }

    .cart-btn {
        width: 30px;
        height: 30px;
        border-radius: 8px;
        flex-shrink: 0;
        background: var(--bg);
        border: 1.5px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--black);
        transition: all .2s;
    }

    .prod-card:hover .cart-btn {
        background: var(--black);
        border-color: var(--black);
        color: #fff;
    }

    /* Promo */
    .promo-wrap {
        padding: 0 40px 60px;
        max-width: 1280px;
        margin: 0 auto;
    }

    .promo {
        border-radius: 20px;
        overflow: hidden;
        background: var(--black);
        display: grid;
        grid-template-columns: 1fr 220px;
        align-items: center;
        padding: 44px 52px;
        position: relative;
    }

    .promo-eye {
        font-size: 10px;
        font-weight: 800;
        letter-spacing: .26em;
        text-transform: uppercase;
        color: #6b7280;
        margin: 0 0 12px;
    }

    .promo-h2 {
        font-family: 'Syne',sans-serif;
        font-size: 2rem;
        font-weight: 900;
        color: #fff;
        line-height: 1.0;
        margin: 0 0 12px;
        letter-spacing: -.025em;
    }

        .promo-h2 .or {
            color: var(--orange);
        }

    .promo-desc {
        color: #6b7280;
        font-size: 13px;
        line-height: 1.65;
        margin: 0 0 22px;
        max-width: 380px;
    }

    .promo-icon {
        width: 140px;
        height: 140px;
        border-radius: 50%;
        background: rgba(255,255,255,.05);
        border: 1px solid rgba(255,255,255,.08);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto;
    }
</style>

<div class="hp">

    <!-- ══ HERO ══ -->
    <div class="hero">
        <div>
            <p class="hero-eye">Next-gen performance</p>
            <h1 class="hero-h1">
                Apex X-1
                <span class="or">Infinite Speed.</span>
            </h1>
            <p class="hero-desc">
                Engineered with the new V3 Carbon chip. Unprecedented
                power efficiency meets raw processing dominance.
            </p>
            <div class="hero-btns">
                <a asp-controller="Products" asp-action="Index" class="btn-ora">Pre-order Now</a>
                <a asp-controller="Products" asp-action="Index" class="btn-out">Watch the Film</a>
            </div>
        </div>
        <div class="hero-imgbox">
            <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuA8qRsVsTMsxREs42pcRJQv2S9EGzkXQ6WQyvfN01clu_zOlPZA8GVuTS0y-bn3Nug7DYItQwHc_2Pk4wttbfS0tdwu0llt6ly6YY7ByPzIsdejGw6E0BhrIOt2o7g5o9iQXb3ut687HIsC_oG8aiC-lzG-KuysxDX8Rlc7I2NqtdYSaPXJUPIAT0q6gc-R2UzFYGcOZZM9LOiX4wAIyXSSVJ8i3TuxHwMIHM2GvfOAq7yqkxUMUepwWva0fudZxZ-LpZGji5eHXWlv"
                 alt="Apex X-1" />
        </div>
    </div>

    <!-- ══ COLLECTIONS ══ -->
    @if (categories.Any())
    {
        <section class="sec">
            <div class="sec-head">
                <div>
                    <p class="sec-eye">Curated Collectives</p>
                    <h2 class="sec-h2">Specialized Tech Architectures</h2>
                </div>
                <a asp-controller="Products" asp-action="Index" class="sec-link">
                    Explore All →
                </a>
            </div>
            @{
                var catList = categories.Take(6).ToList();
                var gridCls = catList.Count > 2 ? "cat-grid3" : "cat-grid2";
            }
            <div class="@gridCls">
                @foreach (var cat in catList)
                {
                    <a class="cat-card" asp-controller="Products" asp-action="Index" asp-route-categoryId="@cat.Id">
                        @if (!string.IsNullOrEmpty(cat.ImageUrl))
                        {
                            <img src="@cat.ImageUrl" alt="@cat.Name" />
                        }
                        else
                        {
                            <div style="position:absolute;inset:0;background:linear-gradient(135deg,#1a1a2e,#16213e);"></div>
                            <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;">
                                <span class="material-symbols-outlined" style="font-size:56px;color:rgba(255,255,255,.07);">category</span>
                            </div>
                        }
                        <div class="cat-ov"></div>
                        <div class="cat-body">
                            @if (!string.IsNullOrEmpty(cat.Description))
                            {
                                <p class="cat-eye">@cat.Description</p>
                            }
                            <p class="cat-name">@cat.Name</p>
                            <span class="cat-cta">Shop @cat.Name →</span>
                        </div>
                    </a>
                }
            </div>
        </section>
    }

    <!-- ══ TRENDING ══ -->
    <section class="sec" style="padding-top:0;">
        <div class="trend-head">
            <div class="trend-left">
                <p class="sec-eye">Real-time Products</p>
                <h2 class="sec-h2" style="font-size:2rem;">Trending Tech Gear</h2>
                <p class="trend-desc">Use structural filters to explore specialized configuration systems.</p>
            </div>
            <div class="pills">
                <a asp-controller="Products" asp-action="Index" class="pill pill-a">View All Collections</a>
                @foreach (var cat in categories.Take(4))
                {
                    <a asp-controller="Products" asp-action="Index"
                       asp-route-categoryId="@cat.Id"
                       class="pill pill-i">@cat.Name</a>
                }
            </div>
        </div>

        @if (Model != null && Model.Items.Any())
        {
            <div class="prod-grid">
                @foreach (var item in Model.Items)
                {
                    <a class="prod-card" asp-controller="Products" asp-action="Detail" asp-route-id="@item.Id">
                        <div class="prod-img">
                            @if (!string.IsNullOrEmpty(item.ThumbnailUrl))
                            {
                                <img src="@item.ThumbnailUrl" alt="@item.Name" />
                            }
                            else
                            {
                                <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;background:#e8e8e6;">
                                    <span class="material-symbols-outlined" style="font-size:40px;color:#bbb;">image_not_supported</span>
                                </div>
                            }
                            @if (item.Stock <= 0)
                            {
                                <span class="prod-badge b-sold">Sold Out</span>
                            }
                            else if (item.IsFeatured)
                            {
                                <span class="prod-badge b-new">New</span>
                            }
                            else if (item.OriginalPrice.HasValue && item.OriginalPrice > item.Price)
                            {
                                var disc = (int)Math.Round((1 - (double)item.Price / (double)item.OriginalPrice.Value) * 100);
                                <span class="prod-badge b-sale">-@disc%</span>
                            }
                        </div>
                        <div class="prod-body">
                            @if (!string.IsNullOrEmpty(item.Brand))
                            {
                                <p class="prod-brand">@item.Brand</p>
                            }
                            <h4 class="prod-name">@item.Name</h4>
                            <div class="prod-footer">
                                <div>
                                    <div class="prod-price">@item.Price.ToString("N0")₫</div>
                                    @if (item.OriginalPrice.HasValue && item.OriginalPrice > item.Price)
                                    {
                                        <div class="prod-orig">@item.OriginalPrice.Value.ToString("N0")₫</div>
                                    }
                                </div>
                                <div class="cart-btn">
                                    <span class="material-symbols-outlined" style="font-size:15px;">shopping_cart</span>
                                </div>
                            </div>
                        </div>
                    </a>
                }
            </div>

            <div style="text-align:center;margin-top:24px;">
                <a asp-controller="Products" asp-action="Index" class="btn-out" style="padding:11px 32px;">
                    Xem tất cả sản phẩm →
                </a>
            </div>
        }
        else
        {
            <div style="text-align:center;padding:48px 0;color:#9ca3af;">
                <span class="material-symbols-outlined" style="font-size:44px;display:block;margin-bottom:10px;color:#d1d5db;">inventory_2</span>
                <p style="font-size:13px;">Chưa có sản phẩm nào.</p>
            </div>
        }
    </section>

    <!-- ══ PROMO ══ -->
    <div class="promo-wrap">
        <div class="promo">
            <div style="position:relative;z-index:1;">
                <p class="promo-eye">Sustainability &amp; Performance</p>
                <h2 class="promo-h2">
                    Upgrade Responsibly.<br />
                    <span class="or">Trade &amp; Save.</span>
                </h2>
                <p class="promo-desc">Get up to $800 in credit toward your next device. Engineered to last, designed to be recycled.</p>
                <a asp-controller="Products" asp-action="Index" class="btn-ora">
                    Estimate Trade-in Value →
                </a>
            </div>
            <div style="position:relative;z-index:1;">
                <div class="promo-icon">
                    <span class="material-symbols-outlined" style="font-size:70px;color:rgba(255,255,255,.14);">devices</span>
                </div>
            </div>
        </div>
    </div>

</div>
