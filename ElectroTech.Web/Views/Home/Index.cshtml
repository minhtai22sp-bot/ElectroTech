@using Entities.ViewModel
@model Library.PaginatedList<ProductIndexModel>

@{
    var categories = ViewBag.Categories as List<Entities.Categories> ?? new();
}

<style>
    /* Dynamic Razor classes that Tailwind CDN can't scan */
    .pill-active {
        background: #f97316;
        color: #fff;
        box-shadow: 0 3px 12px rgba(249,115,22,.35);
    }

    .pill-inactive {
        background: #fff;
        color: #111;
        border: 1.5px solid #e5e5e5;
    }

        .pill-inactive:hover {
            border-color: #111;
        }

    .b-new {
        background: #f97316;
        color: #fff;
    }

    .b-sale {
        background: #111;
        color: #fff;
    }

    .b-sold {
        background: #e5e7eb;
        color: #6b7280;
    }
</style>

<div class="bg-[#f0efed] min-h-screen font-sans text-[#111]">

    <!-- ══ HERO ══ -->
    <section class="max-w-[1280px] mx-auto px-10 pt-16 pb-10 grid grid-cols-2 gap-0 items-center">
        <!-- Left -->
        <div>
            <p class="text-[10px] font-black tracking-[.28em] uppercase text-orange-500 mb-3">
                Next-gen performance
            </p>
            <h1 class="font-black leading-[.9] tracking-[-0.04em] mb-4"
                style="font-size:clamp(2.6rem,4.5vw,4.4rem);">
                Apex X-1<br />
                <span class="text-orange-500">Infinite Speed.</span>
            </h1>
            <p class="text-[13px] text-gray-500 leading-relaxed max-w-sm mb-7">
                Engineered with the new V3 Carbon chip — unprecedented power
                efficiency meets raw processing dominance.
            </p>
            <div class="flex gap-3">
                <a asp-controller="Products" asp-action="Index"
                   class="px-6 py-3 rounded-xl bg-orange-500 text-white text-[13px] font-black
                  shadow-[0_4px_16px_rgba(249,115,22,.4)] hover:bg-orange-600
                  hover:-translate-y-0.5 transition-all">
                    Pre-order Now
                </a>
                <a asp-controller="Products" asp-action="Index"
                   class="px-6 py-3 rounded-xl border-2 border-[#111] text-[13px] font-bold
                  hover:bg-[#111] hover:text-white transition-all">
                    Khám phá →
                </a>
            </div>
        </div>

        <!-- Right — image box -->
        <div class="ml-10 bg-[#e3e2df] rounded-2xl flex items-center justify-center
                overflow-hidden group"
             style="aspect-ratio:1.15/1;padding:36px 28px;">
            <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuA8qRsVsTMsxREs42pcRJQv2S9EGzkXQ6WQyvfN01clu_zOlPZA8GVuTS0y-bn3Nug7DYItQwHc_2Pk4wttbfS0tdwu0llt6ly6YY7ByPzIsdejGw6E0BhrIOt2o7g5o9iQXb3ut687HIsC_oG8aiC-lzG-KuysxDX8Rlc7I2NqtdYSaPXJUPIAT0q6gc-R2UzFYGcOZZM9LOiX4wAIyXSSVJ8i3TuxHwMIHM2GvfOAq7yqkxUMUepwWva0fudZxZ-LpZGji5eHXWlv"
                 alt="Apex X-1"
                 class="w-full max-w-[340px] drop-shadow-2xl
                  group-hover:scale-105 group-hover:-translate-y-2 transition-transform duration-500" />
        </div>
    </section>

    <!-- ══ CATEGORIES ══ -->
    @if (categories.Any())
    {
        <section class="max-w-[1280px] mx-auto px-10 pb-14">
            <div class="flex items-end justify-between mb-5">
                <div>
                    <p class="text-[10px] font-black tracking-[.26em] uppercase text-orange-500 mb-1">Curated Collections</p>
                    <h2 class="text-[1.6rem] font-black tracking-tight leading-tight">Specialized Tech Architectures</h2>
                </div>
                <a asp-controller="Products" asp-action="Index"
                   class="text-orange-500 text-[12px] font-bold hover:gap-2 transition-all inline-flex items-center gap-1">
                    Explore All →
                </a>
            </div>

            @{
                var catList = categories.Take(6).ToList();
                var gridCols = catList.Count > 2 ? "grid-cols-3" : "grid-cols-2";
            }
            <div class="grid @gridCols gap-3">
                @foreach (var cat in catList)
                {
                    <a asp-controller="Products" asp-action="Index" asp-route-categoryId="@cat.Id"
                       class="relative rounded-2xl overflow-hidden block group bg-neutral-800"
                       style="aspect-ratio:16/9;">
                        @if (!string.IsNullOrEmpty(cat.ImageUrl))
                        {
                            <img src="@cat.ImageUrl" alt="@cat.Name"
                                 class="absolute inset-0 w-full h-full object-cover opacity-80
                          group-hover:scale-105 group-hover:opacity-90 transition-all duration-400" />
                        }
                        else
                        {
                            <div class="absolute inset-0 bg-gradient-to-br from-[#1a1a2e] to-[#16213e]"></div>
                            <div class="absolute inset-0 flex items-center justify-center">
                                <span class="material-symbols-outlined" style="font-size:56px;color:rgba(255,255,255,.06);">category</span>
                            </div>
                        }
                        <!-- Overlay -->
                        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/15 to-transparent"></div>
                        <!-- Content -->
                        <div class="absolute bottom-0 left-0 right-0 p-5">
                            @if (!string.IsNullOrEmpty(cat.Description))
                            {
                                <p class="text-[9px] font-black uppercase tracking-[.2em] text-orange-400 mb-1">@cat.Description</p>
                            }
                            <p class="text-white font-black text-[1.2rem] tracking-tight mb-2 leading-tight">@cat.Name</p>
                            <span class="text-white/70 text-[11px] font-bold">Shop @cat.Name →</span>
                        </div>
                    </a>
                }
            </div>
        </section>
    }

    <!-- ══ TRENDING ══ -->
    <section class="max-w-[1280px] mx-auto px-10 pb-16">
        <!-- Header -->
        <div class="flex items-start justify-between gap-6 mb-6">
            <div>
                <p class="text-[10px] font-black tracking-[.26em] uppercase text-orange-500 mb-1">Real-time Products</p>
                <h2 class="text-[2rem] font-black tracking-tight leading-tight">Trending Tech Gear</h2>
                <p class="text-gray-500 text-[12px] mt-1.5 leading-relaxed max-w-xs">
                    Lọc theo danh mục để tìm thiết bị phù hợp.
                </p>
            </div>
            <!-- Pills -->
            <div class="flex gap-2 flex-wrap items-center justify-end pt-1">
                <a asp-controller="Products" asp-action="Index"
                   class="pill-active px-4 py-2 rounded-full text-[11px] font-black transition-all">
                    Tất cả
                </a>
                @foreach (var cat in categories.Take(4))
                {
                    <a asp-controller="Products" asp-action="Index"
                       asp-route-categoryId="@cat.Id"
                       class="pill-inactive px-4 py-2 rounded-full text-[11px] font-bold transition-all">
                        @cat.Name
                    </a>
                }
            </div>
        </div>

        <!-- Grid -->
        @if (Model != null && Model.Items.Any())
        {
            <div class="grid grid-cols-4 gap-3">
                @foreach (var item in Model.Items)
                {
                    <a asp-controller="Products" asp-action="Detail" asp-route-id="@item.Id"
                       class="bg-white rounded-2xl border border-[#e5e5e5] overflow-hidden flex flex-col
                    no-underline group hover:-translate-y-1 hover:shadow-xl transition-all duration-200">

                        <!-- Image -->
                        <div class="relative overflow-hidden bg-[#e8e8e6]" style="aspect-ratio:1">
                            @if (!string.IsNullOrEmpty(item.ThumbnailUrl))
                            {
                                <img src="@item.ThumbnailUrl" alt="@item.Name"
                                     class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
                            }
                            else
                            {
                                <div class="absolute inset-0 flex items-center justify-center">
                                    <span class="material-symbols-outlined text-gray-300" style="font-size:40px;">image_not_supported</span>
                                </div>
                            }
                            @if (item.Stock <= 0)
                            {
                                <span class="b-sold absolute top-2.5 left-2.5 text-[10px] font-black px-2.5 py-1 rounded-full">Hết hàng</span>
                            }
                            else if (item.IsFeatured)
                            {
                                <span class="b-new absolute top-2.5 left-2.5 text-[10px] font-black px-2.5 py-1 rounded-full">New</span>
                            }
                            else if (item.OriginalPrice.HasValue && item.OriginalPrice > item.Price)
                            {
                                var disc = (int)Math.Round((1 - (double)item.Price / (double)item.OriginalPrice.Value) * 100);
                                <span class="b-sale absolute top-2.5 left-2.5 text-[10px] font-black px-2.5 py-1 rounded-full">-@disc%</span>
                            }
                        </div>

                        <!-- Body -->
                        <div class="p-3.5 flex flex-col gap-1 flex-1">
                            @if (!string.IsNullOrEmpty(item.Brand))
                            {
                                <p class="text-[10px] text-gray-400 font-semibold uppercase tracking-wider">@item.Brand</p>
                            }
                            <h4 class="text-[13px] font-black text-orange-500 leading-snug line-clamp-2">@item.Name</h4>

                            <!-- Stars -->
                            <div class="flex items-center gap-0.5">
                                @for (int s = 1; s <= 5; s++)
                                {
                                    <span style="font-size:10px;color:@(s<=(int)Math.Round(item.Rating)?"#f59e0b":"#e5e7eb");">★</span>
                                }
                                <span class="text-[10px] text-gray-300 ml-1">@item.Rating.ToString("0.0")</span>
                            </div>

                            <!-- Footer -->
                            <div class="flex items-end justify-between mt-auto pt-2.5 border-t border-[#f0f0f0]">
                                <div>
                                    <p class="text-[15px] font-black text-orange-500">@item.Price.ToString("N0")₫</p>
                                    @if (item.OriginalPrice.HasValue && item.OriginalPrice > item.Price)
                                    {
                                        <p class="text-[10px] text-gray-300 line-through">@item.OriginalPrice.Value.ToString("N0")₫</p>
                                    }
                                </div>
                                <div class="w-8 h-8 rounded-lg bg-[#f0efed] border border-[#e5e5e5] flex items-center justify-center
                            text-[#111] group-hover:bg-[#111] group-hover:border-[#111] group-hover:text-white
                            transition-all shrink-0">
                                    <span class="material-symbols-outlined" style="font-size:14px;">shopping_cart</span>
                                </div>
                            </div>
                        </div>

                    </a>
                }
            </div>

            <div class="text-center mt-7">
                <a asp-controller="Products" asp-action="Index"
                   class="inline-flex items-center gap-2 px-8 py-3 rounded-xl border-2 border-[#111]
                  text-[13px] font-bold hover:bg-[#111] hover:text-white transition-all">
                    Xem tất cả sản phẩm →
                </a>
            </div>
        }
        else
        {
            <div class="text-center py-16 text-gray-400">
                <span class="material-symbols-outlined block mb-3 text-gray-200" style="font-size:44px;">inventory_2</span>
                <p class="text-[13px]">Chưa có sản phẩm nào.</p>
            </div>
        }
    </section>

    <!-- ══ PROMO BANNER ══ -->
    <div class="max-w-[1280px] mx-auto px-10 pb-20">
        <div class="bg-[#111] rounded-2xl grid grid-cols-[1fr_200px] items-center px-14 py-12 overflow-hidden relative">
            <!-- Decorative circles -->
            <div class="absolute -right-10 -top-10 w-64 h-64 rounded-full border border-white/5"></div>
            <div class="absolute -right-4 -bottom-8 w-40 h-40 rounded-full border border-white/5"></div>

            <div class="relative z-10">
                <p class="text-[10px] font-black tracking-[.26em] uppercase text-gray-600 mb-3">Sustainability & Performance</p>
                <h2 class="text-[2rem] font-black text-white leading-tight tracking-tight mb-3">
                    Upgrade Responsibly.<br />
                    <span class="text-orange-500">Trade &amp; Save.</span>
                </h2>
                <p class="text-gray-500 text-[13px] leading-relaxed max-w-md mb-6">
                    Get up to $800 in credit toward your next device. Engineered to last, designed to be recycled.
                </p>
                <a asp-controller="Products" asp-action="Index"
                   class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-orange-500 text-white
                  text-[13px] font-black shadow-[0_4px_16px_rgba(249,115,22,.4)]
                  hover:bg-orange-600 hover:-translate-y-0.5 transition-all">
                    Estimate Trade-in Value →
                </a>
            </div>

            <div class="relative z-10 flex items-center justify-center">
                <div class="w-36 h-36 rounded-full border border-white/10 bg-white/5 flex items-center justify-center">
                    <span class="material-symbols-outlined" style="font-size:72px;color:rgba(255,255,255,.12);">devices</span>
                </div>
            </div>
        </div>
    </div>

</div>
