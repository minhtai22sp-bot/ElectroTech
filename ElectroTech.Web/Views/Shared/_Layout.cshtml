<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@ViewData["Title"] — ElectroTech</title>

    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['DM Sans', 'Inter', 'sans-serif'],
                    }
                }
            }
        }
    </script>

    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700;800&family=Syne:wght@700;800;900&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet" />

    <style>
        body {
            background: #f0efed;
            color: #111;
            font-family: 'DM Sans',sans-serif;
        }

        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0,'wght' 400,'GRAD' 0,'opsz' 24;
        }
        /* Dropdown hover — không thể dùng Tailwind inline cho pseudo */
        .dd-item:hover {
            background: rgba(0,0,0,.04);
        }

        .dd-item-red:hover {
            background: rgba(249,115,22,.08);
        }
    </style>
</head>
<body>

    <!-- ══ NAVBAR ══ -->
    <nav class="fixed top-0 w-full z-50 bg-white/80 backdrop-blur-xl
                border-b border-black/[0.06] shadow-[0_2px_16px_rgba(0,0,0,.06)]">
        <div class="max-w-[1280px] mx-auto px-8 h-16 flex items-center justify-between gap-6">

            <!-- Logo -->
            <a asp-controller="Home" asp-action="Index"
               class="text-xl font-black tracking-tight text-[#111] no-underline">
                Electro<span class="text-orange-500">Tech</span>
            </a>

            <!-- Nav links -->
            @{
                var ctrl = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
                string NavCls(string name) => ctrl.Equals(name, StringComparison.OrdinalIgnoreCase)
                ? "text-orange-500 font-bold border-b-2 border-orange-500 pb-0.5 text-sm transition-colors no-underline"
                : "text-gray-500 hover:text-[#111] font-semibold text-sm transition-colors no-underline pb-0.5";
            }
            <div class="hidden md:flex items-center gap-8">
                <a asp-controller="Home" asp-action="Index" class="@NavCls("Home")">Home</a>
                <a asp-controller="Products" asp-action="Index" class="@NavCls("Products")">Products</a>
                <a asp-controller="Cart" asp-action="Index" class="@NavCls("Cart")">Cart</a>
            </div>

            <!-- Right side -->
            <div class="flex items-center gap-3">

                <!-- Cart icon -->
                <a asp-controller="Cart" asp-action="Index"
                   class="relative w-10 h-10 rounded-xl flex items-center justify-center
                          text-gray-500 hover:bg-black/[0.06] hover:text-[#111] transition-all no-underline">
                    <span class="material-symbols-outlined" style="font-size:20px;">shopping_cart</span>
                    <span id="cartBadge"
                          class="absolute -top-0.5 -right-0.5 bg-orange-500 text-white
                                 text-[9px] font-black rounded-full w-4 h-4
                                 flex items-center justify-center hidden">0</span>
                </a>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <!-- User dropdown -->
                    <div class="relative" id="userDropdown">
                        <button onclick="toggleDropdown()"
                                class="flex items-center gap-2 px-3 py-2 rounded-xl
                                       text-gray-600 hover:bg-black/[0.06] transition-all">
                            <span class="material-symbols-outlined" style="font-size:20px;">account_circle</span>
                            <span class="hidden md:block text-[13px] font-semibold text-[#111] max-w-[96px] truncate">
                                @User.Identity.Name
                            </span>
                            <span class="material-symbols-outlined text-gray-400" style="font-size:16px;">expand_more</span>
                        </button>

                        <!-- Dropdown -->
                        <div id="dropdownMenu"
                             class="hidden absolute right-0 top-[calc(100%+8px)] w-52 bg-white rounded-2xl
                                    border border-black/[0.08] shadow-[0_16px_48px_rgba(0,0,0,.12)] overflow-hidden z-50">

                            <!-- User info -->
                            <div class="px-4 py-3 border-b border-black/[0.06] bg-black/[0.02]">
                                <p class="text-[10px] text-gray-400 mb-0.5">Xin chào</p>
                                <p class="text-[13px] font-bold text-[#111] truncate">@User.Identity.Name</p>
                            </div>

                            @if (User.IsInRole("SuperAdmin") || User.IsInRole("Admin"))
                            {
                                <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index"
                                   class="dd-item flex items-center gap-2.5 px-4 py-3 text-[13px]
                                          font-semibold text-blue-600 no-underline transition-colors">
                                    <span class="material-symbols-outlined" style="font-size:17px;">dashboard</span>
                                    Admin Panel
                                </a>
                            }

                            <a asp-controller="Orders" asp-action="Index"
                               class="dd-item flex items-center gap-2.5 px-4 py-3 text-[13px]
                                      font-semibold text-gray-700 no-underline transition-colors">
                                <span class="material-symbols-outlined" style="font-size:17px;">package_2</span>
                                Đơn hàng của tôi
                            </a>

                            <div class="border-t border-black/[0.06]">
                                <form asp-controller="Account" asp-action="Logout" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit"
                                            class="dd-item-red w-full flex items-center gap-2.5 px-4 py-3
                                                   bg-transparent border-none text-[13px] font-semibold
                                                   text-orange-500 cursor-pointer text-left transition-colors">
                                        <span class="material-symbols-outlined" style="font-size:17px;">logout</span>
                                        Đăng xuất
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login"
                       class="text-[13px] font-semibold text-gray-500 hover:text-[#111] transition-colors no-underline">
                        Đăng nhập
                    </a>
                    <a asp-controller="Account" asp-action="Register"
                       class="text-[13px] font-black bg-orange-500 text-white px-4 py-2 rounded-xl
                              hover:bg-orange-600 transition-all active:scale-95 no-underline
                              shadow-[0_3px_10px_rgba(249,115,22,.35)]">
                        Đăng ký
                    </a>
                }
            </div>
        </div>
    </nav>

    <!-- Body -->
    <main class="pt-16">
        @RenderBody()
    </main>

    <!-- ══ FOOTER ══ -->
    <footer class="bg-[#111] mt-0">
        <div class="max-w-[1280px] mx-auto px-10 py-14 grid grid-cols-1 md:grid-cols-4 gap-10">

            <div class="flex flex-col gap-4">
                <p class="text-xl font-black text-white tracking-tight">
                    Electro<span class="text-orange-500">Tech</span>
                </p>
                <p class="text-gray-600 text-[12px] uppercase tracking-widest leading-relaxed">
                    © @DateTime.Now.Year ElectroTech.<br />Curating the Future.
                </p>
            </div>

            <div class="flex flex-col gap-3">
                <h5 class="text-white font-black text-[10px] uppercase tracking-[.28em] mb-2">Ecosystem</h5>
                <a class="text-gray-500 hover:text-orange-400 text-[12px] uppercase tracking-widest transition-colors no-underline" href="#">Support</a>
                <a class="text-gray-500 hover:text-orange-400 text-[12px] uppercase tracking-widest transition-colors no-underline" href="#">Store Locator</a>
                <a class="text-gray-500 hover:text-orange-400 text-[12px] uppercase tracking-widest transition-colors no-underline" href="#">Partner Program</a>
            </div>

            <div class="flex flex-col gap-3">
                <h5 class="text-white font-black text-[10px] uppercase tracking-[.28em] mb-2">Legal</h5>
                <a class="text-gray-500 hover:text-orange-400 text-[12px] uppercase tracking-widest transition-colors no-underline" href="#">Privacy Policy</a>
                <a class="text-gray-500 hover:text-orange-400 text-[12px] uppercase tracking-widest transition-colors no-underline" href="#">Terms of Service</a>
                <a class="text-gray-500 hover:text-orange-400 text-[12px] uppercase tracking-widest transition-colors no-underline" href="#">Newsletter</a>
            </div>

            <div class="flex flex-col gap-4">
                <h5 class="text-white font-black text-[10px] uppercase tracking-[.28em] mb-2">Connect</h5>
                <div class="flex gap-3">
                    <a class="w-10 h-10 rounded-full bg-white/5 border border-white/10 flex items-center justify-center
                              text-gray-500 hover:bg-white/10 hover:text-white transition-all no-underline" href="#">
                        <span class="material-symbols-outlined" style="font-size:18px;">share</span>
                    </a>
                    <a class="w-10 h-10 rounded-full bg-white/5 border border-white/10 flex items-center justify-center
                              text-gray-500 hover:bg-white/10 hover:text-white transition-all no-underline" href="#">
                        <span class="material-symbols-outlined" style="font-size:18px;">language</span>
                    </a>
                </div>
            </div>
        </div>

        <div class="max-w-[1280px] mx-auto px-10 py-5 border-t border-white/[0.05]
                    flex flex-col md:flex-row justify-between items-center gap-3">
            <p class="text-[10px] text-gray-700 uppercase tracking-widest">Designed for high-velocity interaction</p>
            <div class="flex gap-4">
                <span class="material-symbols-outlined text-gray-800" style="font-size:15px;">security</span>
                <span class="material-symbols-outlined text-gray-800" style="font-size:15px;">verified</span>
            </div>
        </div>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)

    <script>
        // Cart badge
        fetch('/Cart/Count')
            .then(r => r.json())
            .then(d => {
                const badge = document.getElementById('cartBadge');
                if (badge && d.count > 0) {
                    badge.textContent = d.count;
                    badge.classList.remove('hidden');
                }
            })
            .catch(() => { });

        // Dropdown toggle
        function toggleDropdown() {
            const menu = document.getElementById('dropdownMenu');
            if (!menu) return;
            menu.classList.toggle('hidden');
        }

        // Close dropdown khi click ra ngoài
        document.addEventListener('click', function (e) {
            const dropdown = document.getElementById('userDropdown');
            const menu = document.getElementById('dropdownMenu');
            if (dropdown && menu && !dropdown.contains(e.target)) {
                menu.classList.add('hidden');
            }
        });
    </script>
</body>
</html>
