<!DOCTYPE html>
<html class="dark" lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@ViewData["Title"] — ElectroTech</title>

    {{!-- Tailwind CDN: dùng được MỌI class ngay, không cần build --}}
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    fontFamily: {
                        headline: ['Space Grotesk', 'sans-serif'],
                        label: ['Inter', 'sans-serif'],
                    },
                    colors: {
                        primary: '#adc7ff',
                        'primary-container': '#284777',
                        'on-primary': '#002f65',
                        'on-primary-container': '#d6e3ff',
                        tertiary: '#4ade80',
                        'on-surface': '#e5e2e1',
                        'on-surface-variant': '#9ca3af',
                        outline: '#6b7280',
                        error: '#f87171',
                    }
                }
            }
        }
    </script>

    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300..700&family=Inter:wght@300..700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet" />

    @Html.Raw(@"<style>
    body {
    background-color: #131313;
    color: #e5e2e1;
    font-family: 'Inter', sans-serif;
    }
    .glass {
    background: rgba(19, 19, 19, 0.6);
    backdrop-filter: blur(20px);
    }
    .hero-glow {
    box-shadow: 0 0 80px -20px rgba(173, 199, 255, 0.3);
    }
    .material-symbols-outlined {
    font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    }
    </style>")
</head>
<body>
    <!-- TopNavBar -->
    <nav class="fixed top-0 w-full z-50 bg-gray-900/60 backdrop-blur-xl shadow-[0px_24px_48px_rgba(0,0,0,0.5)]">
        <div class="flex justify-between items-center px-8 py-4 max-w-7xl mx-auto">
            <a asp-controller="Home" asp-action="Index"
               class="text-2xl font-bold tracking-tighter text-blue-400 font-['Space_Grotesk']">
                ElectroTech
            </a>
            @{
                var ctrl = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
                string NavClass(string name) => ctrl.Equals(name, StringComparison.OrdinalIgnoreCase)
                ? "text-blue-400 border-b-2 border-blue-400 pb-1 transition-colors"
                : "text-gray-400 hover:text-blue-400 pb-1 transition-colors";
            }
            <div class="hidden md:flex gap-8 items-center font-['Space_Grotesk'] tracking-tight">
                <a asp-controller="Home" asp-action="Index"
                   class="@NavClass("Home")">Home</a>
                <a asp-controller="Products" asp-action="Index"
                   class="@NavClass("Products")">Products</a>
                <a asp-controller="Cart" asp-action="Index"
                   class="@NavClass("Cart")">Cart</a>
            </div>
            <div class="flex items-center gap-6">
                <!-- Cart -->
                <a asp-controller="Cart" asp-action="Index"
                   class="relative text-gray-400 hover:bg-white/10 p-2 rounded-full
                          transition-all duration-300 active:scale-95">
                    <span class="material-symbols-outlined">shopping_cart</span>
                    <span id="cartBadge"
                          class="absolute -top-1 -right-1 bg-red-500 text-white
                                 text-[10px] font-bold rounded-full w-4 h-4
                                 flex items-center justify-center hidden">0</span>
                </a>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="relative" id="userDropdown">
                        <button onclick="toggleDropdown()"
                                style="background:transparent; border:none; cursor:pointer;
                                       display:flex; align-items:center; gap:8px;
                                       padding:8px; border-radius:999px; color:#9ca3af;
                                       transition:background .2s;"
                                onmouseover="this.style.background='rgba(255,255,255,0.1)'"
                                onmouseout="this.style.background='transparent'">
                            <span class="material-symbols-outlined">account_circle</span>
                            <span class="hidden md:block"
                                  style="font-size:13px; font-weight:600; color:white;
                                         max-width:100px; overflow:hidden; text-overflow:ellipsis;
                                         white-space:nowrap;">
                                @User.Identity.Name
                            </span>
                            <span class="material-symbols-outlined" style="font-size:16px;">expand_more</span>
                        </button>

                        <!-- Dropdown menu -->
                        <div id="dropdownMenu"
                             style="display:none; position:absolute; right:0; top:calc(100% + 8px);
                                    width:200px; background:#1c1b1b; border-radius:12px;
                                    border:1px solid rgba(255,255,255,0.1); overflow:hidden;
                                    box-shadow:0 16px 48px rgba(0,0,0,0.6); z-index:100;">

                            <div style="padding:12px 16px; border-bottom:1px solid rgba(255,255,255,0.08);
                                        background:rgba(255,255,255,0.03);">
                                <p style="font-size:11px; color:#9ca3af; margin:0 0 2px;">Xin chào</p>
                                <p style="font-size:14px; font-weight:700; color:white; margin:0;
                                          overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                                    @User.Identity.Name
                                </p>
                            </div>

                            @if (User.IsInRole("SuperAdmin") || User.IsInRole("Admin"))
                            {
                                <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index"
                                   style="display:flex; align-items:center; gap:10px; padding:12px 16px;
                                          color:#60a5fa; text-decoration:none; font-size:13px;
                                          transition:background .15s;"
                                   onmouseover="this.style.background='rgba(255,255,255,0.05)'"
                                   onmouseout="this.style.background='transparent'">
                                    <span class="material-symbols-outlined" style="font-size:18px;">dashboard</span>
                                    Admin Panel
                                </a>
                            }

                            <a asp-controller="Orders" asp-action="Index"
                               style="display:flex; align-items:center; gap:10px; padding:12px 16px;
                                      color:#d1d5db; text-decoration:none; font-size:13px;
                                      transition:background .15s;"
                               onmouseover="this.style.background='rgba(255,255,255,0.05)'"
                               onmouseout="this.style.background='transparent'">
                                <span class="material-symbols-outlined" style="font-size:18px;">package_2</span>
                                Đơn hàng của tôi
                            </a>

                            <div style="border-top:1px solid rgba(255,255,255,0.08);">
                                <form asp-controller="Account" asp-action="Logout" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit"
                                            style="width:100%; display:flex; align-items:center; gap:10px;
                                                   padding:12px 16px; background:transparent; border:none;
                                                   color:#f87171; font-size:13px; cursor:pointer;
                                                   transition:background .15s; text-align:left;"
                                            onmouseover="this.style.background='rgba(239,68,68,0.1)'"
                                            onmouseout="this.style.background='transparent'">
                                        <span class="material-symbols-outlined" style="font-size:18px;">logout</span>
                                        Đăng xuất
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login"
                       class="text-sm font-bold text-gray-400 hover:text-blue-400 transition-colors">
                        Đăng nhập
                    </a>
                    <a asp-controller="Account" asp-action="Register"
                       class="text-sm font-bold bg-blue-500 text-white px-4 py-2
                              rounded-full hover:bg-blue-600 transition-all active:scale-95">
                        Đăng ký
                    </a>
                }
            </div>
        </div>
    </nav>

    <main class="pt-20">
        @RenderBody()
    </main>

    <footer class="bg-black py-12 px-8">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8 max-w-7xl mx-auto">
            <div class="flex flex-col gap-6">
                <div class="text-xl font-black text-white font-['Inter']">ElectroTech</div>
                <p class="text-gray-500 text-sm uppercase tracking-widest leading-relaxed">
                    © @DateTime.Now.Year ElectroTech. Curating the Future.
                </p>
            </div>
            <div class="flex flex-col gap-4">
                <h5 class="text-white font-bold text-xs uppercase tracking-[0.3em] mb-4">Ecosystem</h5>
                <a class="text-gray-500 hover:text-blue-400 hover:translate-x-1 transition-transform text-sm uppercase tracking-widest" href="#">Support</a>
                <a class="text-gray-500 hover:text-blue-400 hover:translate-x-1 transition-transform text-sm uppercase tracking-widest" href="#">Store Locator</a>
                <a class="text-gray-500 hover:text-blue-400 hover:translate-x-1 transition-transform text-sm uppercase tracking-widest" href="#">Partner Program</a>
            </div>
            <div class="flex flex-col gap-4">
                <h5 class="text-white font-bold text-xs uppercase tracking-[0.3em] mb-4">Legal</h5>
                <a class="text-gray-500 hover:text-blue-400 hover:translate-x-1 transition-transform text-sm uppercase tracking-widest" href="#">Privacy Policy</a>
                <a class="text-gray-500 hover:text-blue-400 hover:translate-x-1 transition-transform text-sm uppercase tracking-widest" href="#">Terms of Service</a>
                <a class="text-gray-500 hover:text-blue-400 hover:translate-x-1 transition-transform text-sm uppercase tracking-widest" href="#">Newsletter</a>
            </div>
            <div class="flex flex-col gap-4">
                <h5 class="text-white font-bold text-xs uppercase tracking-[0.3em] mb-4">Connect</h5>
                <div class="flex gap-4">
                    <a class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center text-gray-500 hover:bg-white/10 transition-all" href="#">
                        <span class="material-symbols-outlined">share</span>
                    </a>
                    <a class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center text-gray-500 hover:bg-white/10 transition-all" href="#">
                        <span class="material-symbols-outlined">language</span>
                    </a>
                </div>
            </div>
        </div>
        <div class="max-w-7xl mx-auto mt-12 pt-8 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-4">
            <div class="text-[10px] text-gray-700 uppercase tracking-widest">Designed for high-velocity interaction</div>
            <div class="flex gap-6">
                <span class="material-symbols-outlined text-gray-800" style="font-size:16px;">security</span>
                <span class="material-symbols-outlined text-gray-800" style="font-size:16px;">verified</span>
            </div>
        </div>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
    <script>
        fetch('/Cart/Count')
            .then(r => r.json())
            .then(d => {
                const badge = document.getElementById('cartBadge');
                if (badge && d.count > 0) {
                    badge.textContent = d.count;
                    badge.classList.remove('hidden');
                }
            })
            .catch(() => { });

        function toggleDropdown() {
            const menu = document.getElementById('dropdownMenu');
            if (!menu) return;
            menu.style.display = menu.style.display === 'none' ? 'block' : 'none';
        }

        document.addEventListener('click', function (e) {
            const dropdown = document.getElementById('userDropdown');
            const menu = document.getElementById('dropdownMenu');
            if (dropdown && menu && !dropdown.contains(e.target)) {
                menu.style.display = 'none';
            }
        });
    </script>
</body>
</html>
