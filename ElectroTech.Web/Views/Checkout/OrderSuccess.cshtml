@model Entities.Order
@{
    ViewData["Title"] = "Đặt hàng thành công";
}

<main class="pt-20 pb-24 min-h-screen" style="background:#0a0a0c;">
    <div class="max-w-2xl mx-auto px-6 py-12">

        <!-- Success Card -->
        <div class="relative rounded-3xl overflow-hidden"
             style="background:#16161a; border:1px solid rgba(255,255,255,0.07);">

            <!-- Top glow -->
            <div class="absolute top-0 left-1/2 -translate-x-1/2 w-80 h-80 rounded-full pointer-events-none"
                 style="background:radial-gradient(circle, rgba(99,102,241,0.12) 0%, transparent 70%);"></div>

            <div class="relative z-10 px-10 py-12 text-center">

                <!-- Icon -->
                <div class="w-24 h-24 rounded-full mx-auto mb-7 flex items-center justify-center"
                     style="background:rgba(74,222,128,0.1); border:2px solid rgba(74,222,128,0.3);">
                    <span class="material-symbols-outlined text-green-400"
                          style="font-size:52px; font-variation-settings:'FILL' 1;">
                        check_circle
                    </span>
                </div>

                <!-- Title -->
                <h1 class="text-4xl font-black text-white mb-2" style="letter-spacing:-.02em;">
                    Đặt hàng thành công!
                </h1>
                <p class="text-gray-400 text-base mb-1">Cảm ơn bạn đã tin tưởng ElectroTech</p>
                <p class="text-gray-500 text-sm mb-8">
                    Mã đơn hàng:
                    <strong class="text-blue-400 text-lg font-black">#@Model.OrderCode</strong>
                </p>

                <!-- Divider -->
                <div class="h-px mb-8" style="background:rgba(255,255,255,0.06);"></div>

                <!-- Steps -->
                <div class="flex items-start justify-center mb-8">
                    <div class="flex flex-col items-center flex-1">
                        <div class="w-10 h-10 bg-blue-600 rounded-full flex items-center justify-center mb-2">
                            <span class="material-symbols-outlined text-white"
                                  style="font-size:20px; font-variation-settings:'FILL' 1;">receipt</span>
                        </div>
                        <p class="text-xs font-bold text-white uppercase tracking-wider mb-0.5">Đặt hàng</p>
                        <p class="text-xs text-green-400 font-semibold">✓ Hoàn thành</p>
                    </div>
                    <div class="h-0.5 flex-1 mt-5" style="background:rgba(37,99,235,0.4);"></div>
                    <div class="flex flex-col items-center flex-1">
                        <div class="w-10 h-10 rounded-full flex items-center justify-center mb-2"
                             style="background:#1f1f27; border:2px solid rgba(255,255,255,0.1);">
                            <span class="material-symbols-outlined text-gray-500" style="font-size:20px;">verified</span>
                        </div>
                        <p class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-0.5">Xác nhận</p>
                        <p class="text-xs text-gray-500 font-semibold">Đang xử lý</p>
                    </div>
                    <div class="h-0.5 flex-1 mt-5" style="background:rgba(255,255,255,0.06);"></div>
                    <div class="flex flex-col items-center flex-1">
                        <div class="w-10 h-10 rounded-full flex items-center justify-center mb-2"
                             style="background:#1f1f27; border:2px solid rgba(255,255,255,0.1);">
                            <span class="material-symbols-outlined text-gray-500" style="font-size:20px;">local_shipping</span>
                        </div>
                        <p class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-0.5">Vận chuyển</p>
                        <p class="text-xs text-gray-500 font-semibold">Chờ xác nhận</p>
                    </div>
                    <div class="h-0.5 flex-1 mt-5" style="background:rgba(255,255,255,0.06);"></div>
                    <div class="flex flex-col items-center flex-1">
                        <div class="w-10 h-10 rounded-full flex items-center justify-center mb-2"
                             style="background:#1f1f27; border:2px solid rgba(255,255,255,0.1);">
                            <span class="material-symbols-outlined text-gray-500" style="font-size:20px;">home</span>
                        </div>
                        <p class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-0.5">Nhận hàng</p>
                        <p class="text-xs text-gray-500 font-semibold">Chờ xác nhận</p>
                    </div>
                </div>

                <!-- Order Info -->
                <div class="rounded-2xl p-5 mb-6 text-left"
                     style="background:#111117; border:1px solid rgba(255,255,255,0.07);">
                    <p class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-4">
                        📦 Thông tin đơn hàng
                    </p>
                    <div class="space-y-2.5">
                        <div class="flex justify-between items-center">
                            <span class="text-gray-400 text-sm">Người nhận</span>
                            <span class="text-white font-semibold text-sm">@Model.FullName</span>
                        </div>
                        <div class="flex justify-between items-center">
                            <span class="text-gray-400 text-sm">Số điện thoại</span>
                            <span class="text-white font-semibold text-sm">@Model.Phone</span>
                        </div>
                        <div class="flex justify-between items-start gap-4">
                            <span class="text-gray-400 text-sm flex-shrink-0">Địa chỉ</span>
                            <span class="text-white font-semibold text-sm text-right">@Model.ShippingAddress</span>
                        </div>
                        <div class="flex justify-between items-center">
                            <span class="text-gray-400 text-sm">Thanh toán</span>
                            <span class="text-sm font-bold @(Model.PaymentMethod == Enums.PaymentMethod.BankTransfer ? "text-yellow-400" : "text-green-400")">
                                @(Model.PaymentMethod == Enums.PaymentMethod.BankTransfer ? "🏦 Chuyển khoản" : "💵 Thanh toán khi nhận hàng")
                            </span>
                        </div>
                        @if (!string.IsNullOrEmpty(Model.Note))
                        {
                            <div class="flex justify-between items-start gap-4">
                                <span class="text-gray-400 text-sm flex-shrink-0">Ghi chú</span>
                                <span class="text-white text-sm text-right">@Model.Note</span>
                            </div>
                        }
                    </div>
                </div>

                <!-- Order Items -->
                <div class="rounded-2xl mb-6 overflow-hidden text-left"
                     style="background:#111117; border:1px solid rgba(255,255,255,0.07);">
                    <div class="px-5 py-3 border-b" style="border-color:rgba(255,255,255,0.06);">
                        <p class="text-xs font-bold text-gray-400 uppercase tracking-wider">
                            🛍️ Sản phẩm (@Model.OrderItems?.Count sản phẩm)
                        </p>
                    </div>
                    @if (Model.OrderItems != null)
                    {
                        foreach (var item in Model.OrderItems)
                        {
                            <div class="flex items-center gap-4 px-5 py-4"
                                 style="border-bottom:1px solid rgba(255,255,255,0.04);">
                                @if (!string.IsNullOrEmpty(item.ProductImage))
                                {
                                    <img src="@item.ProductImage" alt="@item.ProductName"
                                         class="w-14 h-14 rounded-xl object-cover flex-shrink-0"
                                         style="border:1px solid rgba(255,255,255,0.08);" />
                                }
                                else
                                {
                                    <div class="w-14 h-14 rounded-xl flex-shrink-0 flex items-center justify-center"
                                         style="background:#1f1f27;">
                                        <span class="material-symbols-outlined text-gray-600" style="font-size:24px;">image_not_supported</span>
                                    </div>
                                }
                                <div class="flex-1 min-w-0">
                                    <p class="text-white font-semibold text-sm truncate">@item.ProductName</p>
                                    <p class="text-gray-500 text-xs mt-0.5">x@item.Quantity</p>
                                </div>
                                <div class="text-right flex-shrink-0">
                                    <p class="text-white font-bold text-sm">@item.TotalPrice.ToString("N0")₫</p>
                                    <p class="text-gray-500 text-xs">@item.UnitPrice.ToString("N0")₫/sp</p>
                                </div>
                            </div>
                        }
                    }
                    <!-- Total -->
                    <div class="flex justify-between items-center px-5 py-4">
                        <span class="text-gray-400 font-semibold text-sm">Tổng cộng</span>
                        <span class="text-orange-400 font-black text-xl">
                            @Model.TotalAmount.ToString("N0")₫
                        </span>
                    </div>
                </div>

                <!-- Email notice -->
                <div class="rounded-2xl p-4 mb-7 flex items-start gap-3 text-left"
                     style="background:rgba(99,102,241,0.08); border:1px solid rgba(99,102,241,0.2);">
                    <span class="material-symbols-outlined text-indigo-400 mt-0.5 flex-shrink-0"
                          style="font-size:20px; font-variation-settings:'FILL' 1;">
                        mark_email_read
                    </span>
                    <div>
                        <p class="text-indigo-300 text-sm font-bold mb-0.5">Email xác nhận đã được gửi</p>
                        <p class="text-gray-500 text-xs leading-relaxed m-0">
                            Chúng tôi đã gửi email xác nhận đến <strong class="text-gray-400">@Model.Email</strong>.
                            Vui lòng kiểm tra hộp thư (kể cả mục Spam).
                        </p>
                    </div>
                </div>

                <!-- Info boxes -->
                <div class="grid grid-cols-2 gap-3 mb-8">
                    <div class="rounded-xl p-4 text-left"
                         style="background:#111117; border:1px solid rgba(255,255,255,0.06);">
                        <span class="material-symbols-outlined text-blue-500 block mb-1.5"
                              style="font-size:20px;">support_agent</span>
                        <p class="text-xs font-bold text-white mb-0.5">Hỗ trợ 24/7</p>
                        <p class="text-xs text-gray-500">Hotline: 1800 1234</p>
                    </div>
                    <div class="rounded-xl p-4 text-left"
                         style="background:#111117; border:1px solid rgba(255,255,255,0.06);">
                        <span class="material-symbols-outlined text-blue-500 block mb-1.5"
                              style="font-size:20px;">local_shipping</span>
                        <p class="text-xs font-bold text-white mb-0.5">Giao hàng nhanh</p>
                        <p class="text-xs text-gray-500">2-3 ngày làm việc</p>
                    </div>
                </div>

                <!-- CTA Buttons -->
                <div class="flex gap-3 justify-center">
                    <a asp-controller="Home" asp-action="Index"
                       class="px-7 py-3.5 rounded-xl text-sm font-semibold text-gray-400
                              transition-all hover:text-white"
                       style="border:1px solid rgba(255,255,255,0.1); text-decoration:none;"
                       onmouseover="this.style.borderColor='rgba(255,255,255,0.3)'"
                       onmouseout="this.style.borderColor='rgba(255,255,255,0.1)'">
                        ← Trang chủ
                    </a>
                    <a asp-controller="Products" asp-action="Index"
                       class="px-7 py-3.5 bg-blue-600 hover:bg-blue-500 rounded-xl
                              text-white text-sm font-bold transition-all flex items-center gap-2"
                       style="text-decoration:none;">
                        <span class="material-symbols-outlined" style="font-size:18px;">shopping_bag</span>
                        Tiếp tục mua sắm
                    </a>
                </div>

            </div>
        </div>
    </div>
</main>
