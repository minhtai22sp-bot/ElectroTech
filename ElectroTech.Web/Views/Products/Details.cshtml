@model Entities.Product
@{
    ViewData["Title"] = Model.Name;
    var approvedCount = Model.Reviews?.Count(r => r.IsApproved) ?? 0;
}

@Html.AntiForgeryToken()

<style>
    .pd-root {
        background: #f9f7f4;
        min-height: 100vh;
        font-family: 'DM Sans', sans-serif;
    }

    /* breadcrumb */
    .pd-crumb a {
        color: #9ca3af;
        text-decoration: none;
        font-size: 13px;
        transition: color .15s;
    }

        .pd-crumb a:hover {
            color: #1a1a1a;
        }

    .pd-crumb span.sep {
        color: #d1d5db;
        margin: 0 6px;
        font-size: 13px;
    }

    .pd-crumb span.cur {
        color: #374151;
        font-size: 13px;
        font-weight: 500;
    }

    /* image */
    .pd-img-main {
        background: #fff;
        border-radius: 24px;
        border: 1px solid #e5e7eb;
        aspect-ratio: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 32px;
        overflow: hidden;
        box-shadow: 0 4px 24px rgba(0,0,0,.05);
        cursor: zoom-in;
        transition: box-shadow .2s;
    }

        .pd-img-main:hover {
            box-shadow: 0 8px 40px rgba(0,0,0,.1);
        }

    .pd-img-thumb {
        background: #fff;
        border-radius: 14px;
        border: 2px solid #e5e7eb;
        aspect-ratio: 1;
        cursor: pointer;
        padding: 6px;
        overflow: hidden;
        transition: border-color .2s, transform .15s;
    }

        .pd-img-thumb:hover {
            transform: translateY(-2px);
            border-color: #6366f1;
        }

        .pd-img-thumb.active {
            border-color: #6366f1;
            box-shadow: 0 0 0 3px rgba(99,102,241,.12);
        }

    /* badge */
    .badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: .06em;
        text-transform: uppercase;
    }

    .badge-featured {
        background: #ede9fe;
        color: #7c3aed;
        border: 1px solid #ddd6fe;
    }

    .badge-instock {
        background: #dcfce7;
        color: #16a34a;
        border: 1px solid #bbf7d0;
    }

    .badge-outstock {
        background: #fee2e2;
        color: #dc2626;
        border: 1px solid #fecaca;
    }

    /* price */
    .pd-price {
        background: linear-gradient(135deg, #f5f3ff, #ede9fe);
        border: 1px solid #ddd6fe;
        border-radius: 18px;
        padding: 22px 24px;
    }

    /* spec highlight card */
    .spec-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        padding: 14px 16px;
        display: flex;
        align-items: flex-start;
        gap: 12px;
        transition: border-color .2s, box-shadow .2s;
    }

        .spec-card:hover {
            border-color: #a5b4fc;
            box-shadow: 0 4px 16px rgba(99,102,241,.08);
        }

    /* qty */
    .qty-wrap {
        display: flex;
        align-items: center;
        background: #fff;
        border: 1.5px solid #e5e7eb;
        border-radius: 14px;
        overflow: hidden;
        transition: border-color .2s;
    }

        .qty-wrap:focus-within {
            border-color: #6366f1;
        }

    .qty-btn {
        width: 44px;
        height: 44px;
        border: none;
        background: none;
        cursor: pointer;
        color: #9ca3af;
        font-size: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: color .15s, background .15s;
    }

        .qty-btn:hover {
            color: #6366f1;
            background: #f5f3ff;
        }

    .qty-num {
        width: 48px;
        text-align: center;
        font-weight: 800;
        font-size: 16px;
        color: #111827;
        user-select: none;
    }

    /* buttons */
    .btn-cart {
        flex: 1;
        padding: 16px 24px;
        border: none;
        border-radius: 16px;
        font-size: 15px;
        font-weight: 700;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        color: #fff;
        transition: all .25s;
        box-shadow: 0 8px 24px rgba(99,102,241,.3);
    }

        .btn-cart:hover:not(:disabled) {
            transform: translateY(-2px);
            box-shadow: 0 12px 32px rgba(99,102,241,.45);
        }

        .btn-cart:disabled {
            background: #f3f4f6;
            color: #9ca3af;
            box-shadow: none;
            cursor: not-allowed;
        }

    .btn-wish {
        width: 56px;
        height: 56px;
        border: 1.5px solid #e5e7eb;
        border-radius: 16px;
        background: #fff;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #9ca3af;
        transition: all .2s;
    }

        .btn-wish:hover {
            color: #ef4444;
            border-color: #fca5a5;
            background: #fff5f5;
        }

    /* tab */
    .tab-btn {
        padding: 12px 24px;
        border: none;
        background: none;
        cursor: pointer;
        font-size: 14px;
        font-weight: 600;
        color: #9ca3af;
        border-bottom: 2px solid transparent;
        margin-bottom: -1px;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: all .2s;
        font-family: 'DM Sans', sans-serif;
    }

        .tab-btn.active {
            color: #6366f1;
            border-bottom-color: #6366f1;
        }

        .tab-btn:hover:not(.active) {
            color: #374151;
        }

    /* spec table */
    .spec-group {
        background: #fff;
        border-radius: 16px;
        overflow: hidden;
        border: 1px solid #e5e7eb;
    }

    .spec-group-head {
        background: #f5f3ff;
        padding: 11px 24px;
        border-bottom: 1px solid #ede9fe;
    }

        .spec-group-head h3 {
            color: #6366f1;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .18em;
            margin: 0;
        }

    .spec-row-even {
        background: #fff;
    }

    .spec-row-odd {
        background: #fafafa;
    }

    /* review */
    .star-bar-fill {
        background: linear-gradient(90deg,#6366f1,#a78bfa);
    }

    .review-card {
        background: #fff;
        border-radius: 16px;
        padding: 22px 24px;
        border: 1px solid #e5e7eb;
    }

    .verified-badge {
        background: #dcfce7;
        color: #16a34a;
        font-size: 10px;
        font-weight: 700;
        padding: 2px 8px;
        border-radius: 10px;
    }

    /* toast */
    #cartToast {
        position: fixed;
        bottom: 32px;
        right: 32px;
        z-index: 9999;
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 16px 20px;
        border-radius: 18px;
        background: #fff;
        min-width: 300px;
        border: 1px solid #e5e7eb;
        box-shadow: 0 20px 60px rgba(0,0,0,.12);
        opacity: 0;
        transform: translateY(16px);
        transition: all .3s cubic-bezier(.34,1.56,.64,1);
        pointer-events: none;
    }
</style>

<main class="pd-root pt-20 pb-24">
    <div style="max-width:1280px;margin:0 auto;padding:0 40px;">

        <!-- Breadcrumb -->
        <nav class="pd-crumb" style="display:flex;align-items:center;margin-bottom:36px;padding-top:28px;">
            <a asp-controller="Home" asp-action="Index">Trang chủ</a>
            <span class="sep">›</span>
            <a asp-controller="Products" asp-action="Index">Sản phẩm</a>
            <span class="sep">›</span>
            <span class="cur">@Model.Name</span>
        </nav>

        <!-- Main grid -->
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:56px;margin-bottom:72px;align-items:start;">

            <!-- LEFT: Images -->
            <div>
                <div class="pd-img-main" style="margin-bottom:14px;">
                    @if (!string.IsNullOrEmpty(Model.ThumbnailUrl))
                    {
                        <img id="mainImage" src="@Model.ThumbnailUrl" alt="@Model.Name"
                             style="width:100%;height:100%;object-fit:contain;transition:opacity .2s;" />
                    }
                    else
                    {
                        <span class="material-symbols-outlined" style="font-size:80px;color:#d1d5db;">image_not_supported</span>
                    }
                </div>

                @if (Model.ProductImages != null && Model.ProductImages.Any())
                {
                    <div style="display:grid;grid-template-columns:repeat(5,1fr);gap:10px;">
                        <div class="pd-img-thumb active" onclick="changeImage('@Model.ThumbnailUrl', this)">
                            <img src="@Model.ThumbnailUrl" alt="" style="width:100%;height:100%;object-fit:contain;" />
                        </div>
                        @foreach (var img in Model.ProductImages)
                        {
                            <div class="pd-img-thumb" onclick="changeImage('@img.ImageUrl', this)">
                                <img src="@img.ImageUrl" alt="" style="width:100%;height:100%;object-fit:contain;" />
                            </div>
                        }
                    </div>
                }
            </div>

            <!-- RIGHT: Info -->
            <div style="display:flex;flex-direction:column;gap:20px;">

                <!-- Badges -->
                <div style="display:flex;gap:8px;flex-wrap:wrap;">
                    @if (Model.IsFeatured)
                    {
                        <span class="badge badge-featured">⚡ Nổi bật</span>
                    }
                    @if (Model.Stock <= 0)
                    {
                        <span class="badge badge-outstock">Hết hàng</span>
                    }
                    else
                    {
                        <span class="badge badge-instock">
                            <span style="width:6px;height:6px;background:#16a34a;border-radius:50%;display:inline-block;"></span>
                            Còn hàng (@Model.Stock)
                        </span>
                    }
                </div>

                @if (!string.IsNullOrEmpty(Model.Brand))
                {
                    <p style="color:#6366f1;font-size:11px;font-weight:800;
                               text-transform:uppercase;letter-spacing:.2em;margin:0;">
                        @Model.Brand
                    </p>
                }

                <h1 style="font-size:2rem;font-weight:800;color:#111827;
                            line-height:1.2;margin:0;letter-spacing:-.02em;
                            font-family:'Syne',sans-serif;">
                    @Model.Name
                </h1>

                <!-- Rating -->
                <div style="display:flex;align-items:center;gap:8px;">
                    <div style="display:flex;gap:2px;">
                        @for (int i = 1; i <= 5; i++)
                        {
                            var starColor = i <= (int)Model.Rating ? "#f59e0b" : "#e5e7eb";
                            <span style="font-size:15px;color:@starColor;">★</span>
                        }
                    </div>
                    <span style="color:#6b7280;font-size:13px;">
                        @Model.Rating.ToString("0.0") · @Model.ReviewCount đánh giá
                    </span>
                </div>

                <!-- Price -->
                <div class="pd-price">
                    <div style="display:flex;align-items:baseline;gap:12px;flex-wrap:wrap;">
                        <span style="font-size:2.2rem;font-weight:900;color:#6366f1;
                                     letter-spacing:-.03em;font-family:'Syne',sans-serif;">
                            @Model.Price.ToString("N0")₫
                        </span>
                        @if (Model.OriginalPrice.HasValue && Model.OriginalPrice > Model.Price)
                        {
                            var discount = (int)((1 - Model.Price / Model.OriginalPrice.Value) * 100);
                            <span style="font-size:1rem;color:#9ca3af;text-decoration:line-through;">
                                @Model.OriginalPrice.Value.ToString("N0")₫
                            </span>
                            <span style="background:#dc2626;color:white;font-size:11px;
                                         font-weight:800;padding:3px 10px;border-radius:20px;">
                                −@discount%
                            </span>
                        }
                    </div>
                </div>

                <!-- Highlight specs -->
                @if (Model.ProductSpecs != null && Model.ProductSpecs.Any())
                {
                    var highlight = new[] { "CPU", "RAM", "Storage", "Refresh Rate", "Rear Camera", "Battery Capacity", "Screen Size", "Processor" };
                    var icons = new Dictionary<string, string>
                {
                    ["CPU"] = "memory",
                    ["Processor"] = "memory",
                    ["RAM"] = "storage",
                    ["Storage"] = "database",
                    ["Screen Size"] = "monitor",
                    ["Refresh Rate"] = "refresh",
                    ["Rear Camera"] = "photo_camera",
                    ["Battery Capacity"] = "battery_full"
                };
                    var highlightSpecs = Model.ProductSpecs
                    .Where(s => highlight.Contains(s.SpecKey))
                    .OrderBy(s => s.DisplayOrder).Take(4).ToList();

                    if (highlightSpecs.Any())
                    {
                        <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
                            @foreach (var spec in highlightSpecs)
                            {
                                var icon = icons.ContainsKey(spec.SpecKey) ? icons[spec.SpecKey] : "info";
                                <div class="spec-card">
                                    <span class="material-symbols-outlined"
                                          style="color:#6366f1;font-size:20px;margin-top:2px;">@icon</span>
                                    <div>
                                        <p style="color:#9ca3af;font-size:9px;font-weight:700;
                                                   text-transform:uppercase;letter-spacing:.15em;margin:0 0 4px;">
                                            @spec.SpecKey
                                        </p>
                                        <p style="color:#111827;font-weight:700;font-size:13px;margin:0;">
                                            @spec.SpecValue
                                        </p>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                }

                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <p style="color:#6b7280;font-size:14px;line-height:1.75;margin:0;">
                        @Model.Description
                    </p>
                }

                <!-- Quantity -->
                @if (Model.Stock > 0)
                {
                    <div style="display:flex;align-items:center;gap:14px;">
                        <span style="color:#9ca3af;font-size:12px;font-weight:700;
                                     text-transform:uppercase;letter-spacing:.12em;">
                            Số lượng
                        </span>
                        <div class="qty-wrap">
                            <button type="button" id="btnMinus" class="qty-btn" onclick="changeQty(-1)">
                                <span class="material-symbols-outlined" style="font-size:18px;">remove</span>
                            </button>
                            <span class="qty-num" id="qtyDisplay">1</span>
                            <button type="button" id="btnPlus" class="qty-btn" onclick="changeQty(1)">
                                <span class="material-symbols-outlined" style="font-size:18px;">add</span>
                            </button>
                        </div>
                        <span style="color:#9ca3af;font-size:13px;">
                            / <span style="color:#374151;font-weight:600;">@Model.Stock</span> sản phẩm
                        </span>
                    </div>
                }

                <!-- Buttons -->
                <div style="display:flex;gap:12px;">
                    <button id="addToCartBtn"
                            class="btn-cart"
                            data-product-id="@Model.Id"
                            data-max-stock="@Model.Stock"
                    @(Model.Stock <= 0 ? "disabled" : "")>
                        <span class="material-symbols-outlined" style="font-size:20px;">add_shopping_cart</span>
                        <span id="addBtnText">@(Model.Stock > 0 ? "Thêm vào giỏ" : "Hết hàng")</span>
                    </button>
                    <button class="btn-wish">
                        <span class="material-symbols-outlined" style="font-size:22px;">favorite_border</span>
                    </button>
                </div>

                @if (!string.IsNullOrEmpty(Model.Code))
                {
                    <p style="color:#d1d5db;font-size:12px;margin:0;">
                        SKU: <span style="color:#9ca3af;font-family:monospace;">@Model.Code</span>
                    </p>
                }
            </div>
        </div>

        <!-- ── TABS ── -->
        <div style="margin-bottom:80px;">

            <!-- Tab buttons -->
            <div style="display:flex;border-bottom:1px solid #e5e7eb;margin-bottom:32px;">
                <button id="tab-specs" class="tab-btn active" onclick="switchTab('specs')">
                    <span class="material-symbols-outlined" style="font-size:18px;">tune</span>
                    Thông số kỹ thuật
                    @if (Model.ProductSpecs != null && Model.ProductSpecs.Any())
                    {
                        <span style="background:#ede9fe;color:#6366f1;font-size:10px;
                                     font-weight:700;padding:2px 8px;border-radius:10px;">
                            @Model.ProductSpecs.Count
                        </span>
                    }
                </button>
                <button id="tab-reviews" class="tab-btn" onclick="switchTab('reviews')">
                    <span class="material-symbols-outlined" style="font-size:18px;">star</span>
                    Đánh giá
                    @if (approvedCount > 0)
                    {
                        <span id="reviewBadge"
                              style="background:#f3f4f6;color:#9ca3af;font-size:10px;
                                     font-weight:700;padding:2px 8px;border-radius:10px;">
                            @approvedCount
                        </span>
                    }
                </button>
            </div>

            <!-- Panel: Thông số -->
            <div id="panel-specs">
                @if (Model.ProductSpecs != null && Model.ProductSpecs.Any())
                {
                    var specGroups = Model.ProductSpecs
                    .OrderBy(s => s.DisplayOrder)
                    .GroupBy(s => string.IsNullOrEmpty(s.GroupName) ? "Thông số chung" : s.GroupName);

                    <div style="display:flex;flex-direction:column;gap:12px;">
                        @foreach (var group in specGroups)
                        {
                            var specList = group.ToList();
                            <div class="spec-group">
                                <div class="spec-group-head">
                                    <h3>@group.Key</h3>
                                </div>
                                <table style="width:100%;border-collapse:collapse;">
                                    @for (int idx = 0; idx < specList.Count; idx++)
                                    {
                                        var spec = specList[idx];
                                        var rowCls = idx % 2 == 0 ? "spec-row-even" : "spec-row-odd";
                                        <tr class="@rowCls" style="border-bottom:1px solid #f3f4f6;">
                                            <td style="padding:13px 24px;color:#6b7280;font-size:13px;font-weight:600;width:40%;">
                                                @spec.SpecKey
                                            </td>
                                            <td style="padding:13px 24px;color:#111827;font-size:13px;">
                                                @spec.SpecValue
                                            </td>
                                        </tr>
                                    }
                                </table>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div style="text-align:center;padding:60px 0;color:#d1d5db;">
                        <span class="material-symbols-outlined" style="font-size:48px;display:block;margin-bottom:12px;">tune</span>
                        <p style="font-size:14px;color:#9ca3af;">Chưa có thông số kỹ thuật.</p>
                    </div>
                }
            </div>

            <!-- Panel: Đánh giá -->
            <div id="panel-reviews" style="display:none;">
                <!-- Form viết đánh giá -->
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="mt-8 bg-[#16161a] border border-white/5 rounded-2xl p-6">
                        <h3 class="text-white font-bold text-base mb-5">
                            ✍️ Viết đánh giá của bạn
                        </h3>
                        <form asp-controller="Review" asp-action="Create"
                              method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="productId" value="@Model.Id" />

                            <!-- Star rating -->
                            <div class="mb-5">
                                <label class="text-xs font-bold text-[#6b7280] uppercase
                               tracking-wider mb-3 block">
                                    Đánh giá *
                                </label>
                                <div class="flex gap-2" id="starRating">
                                    @for (int s = 1; s <= 5; s++)
                                    {
                                        <button type="button"
                                                onclick="setRating(@s)"
                                                id="star-@s"
                                                class="text-3xl text-[#2a2a35] hover:text-yellow-400
                                       transition-colors cursor-pointer
                                       bg-none border-none">
                                            ★
                                        </button>
                                    }
                                </div>
                                <input type="hidden" name="rating" id="ratingInput" value="0" />
                                <p id="ratingError"
                                   class="text-red-400 text-xs mt-1 hidden">
                                    Vui lòng chọn số sao
                                </p>
                            </div>

                            <!-- Title -->
                            <div class="mb-4">
                                <label class="text-xs font-bold text-[#6b7280] uppercase
                               tracking-wider mb-2 block">
                                    Tiêu đề
                                </label>
                                <input type="text" name="title"
                                       placeholder="Tóm tắt trải nghiệm của bạn..."
                                       maxlength="200"
                                       class="w-full bg-[#1c1c22] border border-white/8
                              rounded-xl px-4 py-3 text-white text-sm
                              outline-none focus:border-[#adc7ff]/50
                              focus:ring-1 focus:ring-[#adc7ff]/30
                              placeholder-[#374151] transition-all" />
                            </div>

                            <!-- Comment -->
                            <div class="mb-5">
                                <label class="text-xs font-bold text-[#6b7280] uppercase
                               tracking-wider mb-2 block">
                                    Nội dung đánh giá *
                                </label>
                                <textarea name="comment" required rows="4"
                                          maxlength="1000"
                                          placeholder="Chia sẻ chi tiết trải nghiệm của bạn..."
                                          class="w-full bg-[#1c1c22] border border-white/8
                                 rounded-xl px-4 py-3 text-white text-sm
                                 outline-none focus:border-[#adc7ff]/50
                                 focus:ring-1 focus:ring-[#adc7ff]/30
                                 placeholder-[#374151] resize-none
                                 transition-all"></textarea>
                            </div>

                            <button type="submit" onclick="return validateReview()"
                                    class="px-7 py-3 bg-gradient-to-r from-[#adc7ff]
                           to-[#7ca4f4] text-[#0d1b3e] font-bold
                           rounded-xl text-sm hover:shadow-[0_8px_24px_rgba(173,199,255,0.3)]
                           hover:-translate-y-0.5 transition-all
                           cursor-pointer border-none">
                                Gửi đánh giá
                            </button>
                        </form>
                    </div>
                }
                else
                {
                    <div class="mt-8 bg-[#16161a] border border-white/5 rounded-2xl
                p-8 text-center">
                        <p class="text-[#6b7280] text-sm mb-4">
                            Đăng nhập để viết đánh giá
                        </p>
                        <a asp-controller="Account" asp-action="Login"
                           class="px-6 py-2.5 bg-[#adc7ff]/10 border border-[#adc7ff]/20
                  text-[#adc7ff] font-bold rounded-xl text-sm
                  hover:bg-[#adc7ff]/15 transition-colors no-underline
                  inline-block">
                            Đăng nhập
                        </a>
                    </div>
                }
                @if (Model.Reviews != null && Model.Reviews.Any(r => r.IsApproved))
                {
                    <!-- Rating summary -->
                    <div style="display:flex;align-items:center;gap:32px;background:#fff;
                                border:1px solid #e5e7eb;border-radius:20px;
                                padding:28px 32px;margin-bottom:20px;
                                box-shadow:0 2px 12px rgba(0,0,0,.04);">
                        <div style="text-align:center;flex-shrink:0;">
                            <p style="font-size:3.5rem;font-weight:900;color:#111827;
                                      line-height:1;margin:0 0 6px;font-family:'Syne',sans-serif;">
                                @Model.Rating.ToString("0.0")
                            </p>
                            <div style="display:flex;gap:2px;justify-content:center;margin-bottom:4px;">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    var sc = i <= (int)Math.Round(Model.Rating) ? "#f59e0b" : "#e5e7eb";
                                    <span style="font-size:16px;color:@sc;">★</span>
                                }
                            </div>
                            <p style="color:#9ca3af;font-size:12px;margin:0;">@approvedCount đánh giá</p>
                        </div>
                        <div style="flex:1;display:flex;flex-direction:column;gap:7px;">
                            @for (int star = 5; star >= 1; star--)
                            {
                                var cnt = Model.Reviews.Count(r => r.IsApproved && r.Rating == star);
                                var pct = approvedCount > 0 ? (int)((double)cnt / approvedCount * 100) : 0;
                                <div style="display:flex;align-items:center;gap:10px;">
                                    <span style="color:#6b7280;font-size:11px;font-weight:600;width:12px;text-align:right;">@star</span>
                                    <span style="color:#f59e0b;font-size:11px;">★</span>
                                    <div style="flex:1;height:6px;background:#f3f4f6;border-radius:3px;overflow:hidden;">
                                        <div class="star-bar-fill" style="height:100%;border-radius:3px;width:@(pct)%;transition:width .6s ease;"></div>
                                    </div>
                                    <span style="color:#9ca3af;font-size:11px;width:28px;">@cnt</span>
                                </div>
                            }
                        </div>
                    </div>

                    <!-- Review list -->
                    <div style="display:flex;flex-direction:column;gap:12px;">
                        @foreach (var review in Model.Reviews.Where(r => r.IsApproved).OrderByDescending(r => r.CreatedOn))
                        {
                            <div class="review-card">
                                <div style="display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:14px;">
                                    <div style="display:flex;align-items:center;gap:12px;">
                                        <div style="width:40px;height:40px;border-radius:50%;flex-shrink:0;
                                                    background:linear-gradient(135deg,#6366f1,#a78bfa);
                                                    display:flex;align-items:center;justify-content:center;">
                                            <span class="material-symbols-outlined" style="color:#fff;font-size:18px;">person</span>
                                        </div>
                                        <div>
                                            <p style="color:#111827;font-weight:700;font-size:14px;margin:0 0 3px;">
                                                Người dùng #@(review.UserId.ToString()[..8])
                                            </p>
                                            <div style="display:flex;align-items:center;gap:8px;">
                                                <span style="color:#9ca3af;font-size:12px;">@review.CreatedOn.ToString("dd/MM/yyyy")</span>
                                                @if (review.IsVerifiedPurchase)
                                                {
                                                    <span class="verified-badge">✓ Đã mua hàng</span>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                    <div style="display:flex;gap:2px;">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            var sc2 = i <= review.Rating ? "#f59e0b" : "#e5e7eb";
                                            <span style="font-size:14px;color:@sc2;">★</span>
                                        }
                                    </div>
                                </div>
                                @if (!string.IsNullOrEmpty(review.Title))
                                {
                                    <p style="color:#111827;font-weight:700;font-size:14px;margin:0 0 8px;">@review.Title</p>
                                }
                                <p style="color:#6b7280;font-size:14px;line-height:1.7;margin:0;">@review.Comment</p>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div style="text-align:center;padding:60px 0;">
                        <span class="material-symbols-outlined" style="font-size:48px;display:block;margin-bottom:12px;color:#d1d5db;">rate_review</span>
                        <p style="font-size:14px;color:#9ca3af;">Chưa có đánh giá nào.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</main>

<!-- Toast -->
<div id="cartToast">
    <div id="toastIconWrap"
         style="width:40px;height:40px;border-radius:50%;flex-shrink:0;
                background:#ede9fe;display:flex;align-items:center;justify-content:center;">
        <span class="material-symbols-outlined" id="toastIconSymbol"
              style="font-size:20px;color:#6366f1;">check</span>
    </div>
    <span id="toastMsg" style="color:#111827;font-size:14px;font-weight:500;flex:1;">
        Đã thêm vào giỏ!
    </span>
    <a href="/Cart"
       style="color:#6366f1;font-size:12px;font-weight:700;text-decoration:none;
              padding:5px 12px;border:1.5px solid #c7d2fe;border-radius:8px;
              white-space:nowrap;background:#f5f3ff;transition:background .15s;"
       onmouseover="this.style.background='#ede9fe'"
       onmouseout="this.style.background='#f5f3ff'">
        Xem giỏ →
    </a>
</div>

@section Scripts {

    <script>
        // Star rating
        var selectedRating = 0;

        function setRating(val) {
            selectedRating = val;
            document.getElementById('ratingInput').value = val;
            document.getElementById('ratingError').classList.add('hidden');

            for (var i = 1; i <= 5; i++) {
                var star = document.getElementById('star-' + i);
                if (i <= val) {
                    star.style.color = '#facc15';
                } else {
                    star.style.color = '#2a2a35';
                }
            }
        }

        // Hover effect
        for (var i = 1; i <= 5; i++) {
            (function (idx) {
                var star = document.getElementById('star-' + idx);
                if (!star) return;
                star.addEventListener('mouseover', function () {
                    for (var j = 1; j <= 5; j++) {
                        document.getElementById('star-' + j).style.color =
                            j <= idx ? '#facc15' : '#2a2a35';
                    }
                });
                star.addEventListener('mouseout', function () {
                    for (var j = 1; j <= 5; j++) {
                        document.getElementById('star-' + j).style.color =
                            j <= selectedRating ? '#facc15' : '#2a2a35';
                    }
                });
            })(i);
        }

        function validateReview() {
            if (selectedRating === 0) {
                document.getElementById('ratingError').classList.remove('hidden');
                return false;
            }
            return true;
        }
        var activeTab = 'specs';

        function switchTab(tab) {
            activeTab = tab;
            var tSpecs = document.getElementById('tab-specs');
            var tReviews = document.getElementById('tab-reviews');
            var pSpecs = document.getElementById('panel-specs');
            var pReviews = document.getElementById('panel-reviews');
            var badge = document.getElementById('reviewBadge');

            if (tab === 'specs') {
                tSpecs.classList.add('active');
                tReviews.classList.remove('active');
                if (badge) { badge.style.background = '#f3f4f6'; badge.style.color = '#9ca3af'; }
                pSpecs.style.display = 'block';
                pReviews.style.display = 'none';
            } else {
                tReviews.classList.add('active');
                tSpecs.classList.remove('active');
                if (badge) { badge.style.background = '#ede9fe'; badge.style.color = '#6366f1'; }
                pSpecs.style.display = 'none';
                pReviews.style.display = 'block';
            }
        }

        function changeImage(url, el) {
            var img = document.getElementById('mainImage');
            if (!img) return;
            img.style.opacity = '0';
            setTimeout(function () { img.src = url; img.style.opacity = '1'; }, 150);
            document.querySelectorAll('.pd-img-thumb').forEach(function (t) {
                t.classList.remove('active');
            });
            if (el) el.classList.add('active');
        }

        var qty = 1;
        var maxStock = parseInt(document.getElementById('addToCartBtn')?.dataset.maxStock ?? '0');

        function changeQty(delta) {
            qty = Math.max(1, Math.min(maxStock, qty + delta));
            document.getElementById('qtyDisplay').textContent = qty;
            var minus = document.getElementById('btnMinus');
            var plus = document.getElementById('btnPlus');
            if (minus) minus.disabled = qty <= 1;
            if (plus) plus.disabled = qty >= maxStock;
        }
        changeQty(0);

        var toastTimer;
        function showToast(msg, type) {
            var toast = document.getElementById('cartToast');
            var symbol = document.getElementById('toastIconSymbol');
            var wrap = document.getElementById('toastIconWrap');
            var msgEl = document.getElementById('toastMsg');
            symbol.textContent = type === 'success' ? 'check' : 'error';
            symbol.style.color = type === 'success' ? '#6366f1' : '#ef4444';
            wrap.style.background = type === 'success' ? '#ede9fe' : '#fee2e2';
            toast.style.borderColor = type === 'success' ? '#c7d2fe' : '#fecaca';
            msgEl.textContent = msg;
            toast.style.opacity = '1';
            toast.style.transform = 'translateY(0)';
            toast.style.pointerEvents = 'auto';
            clearTimeout(toastTimer);
            toastTimer = setTimeout(function () {
                toast.style.opacity = '0';
                toast.style.transform = 'translateY(16px)';
                toast.style.pointerEvents = 'none';
            }, 3000);
        }

        var addBtn = document.getElementById('addToCartBtn');
        if (addBtn && !addBtn.disabled) {
            addBtn.addEventListener('click', async function () {
                var productId = this.dataset.productId;
                var token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
                var btnText = document.getElementById('addBtnText');
                var fd = new FormData();
                fd.append('productId', productId);
                fd.append('quantity', qty);
                fd.append('__RequestVerificationToken', token);
                var original = btnText.textContent;
                btnText.textContent = 'Đang thêm...';
                this.disabled = true;
                try {
                    var res = await fetch('/Cart/Add', { method: 'POST', body: fd });
                    var data = await res.json();
                    if (data.success) {
                        var badge = document.getElementById('cartBadge');
                        if (badge) { badge.textContent = data.count; badge.classList.remove('hidden'); }
                        showToast('Đã thêm ' + qty + ' sản phẩm vào giỏ!', 'success');
                        btnText.textContent = '✓ Đã thêm!';
                        setTimeout(function () { btnText.textContent = original; addBtn.disabled = false; }, 1500);
                    } else {
                        showToast(data.message ?? 'Có lỗi xảy ra.', 'error');
                        btnText.textContent = original;
                        addBtn.disabled = false;
                    }
                } catch (e) {
                    showToast('Có lỗi xảy ra, vui lòng thử lại.', 'error');
                    btnText.textContent = original;
                    addBtn.disabled = false;
                }
            });
        }
    </script>
}
