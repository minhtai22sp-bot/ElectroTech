@using Entities.ViewModel
@model Library.PaginatedList<ProductIndexModel>

@{
    var categories = ViewBag.Categories as List<Entities.Categories> ?? new();
    var currentCat = ViewBag.CategoryId as int? ?? 0;
    var currentQ = ViewBag.SearchQuery as string ?? "";
    var currentSort = ViewBag.SortBy as string ?? "";
    var totalCount = Model?.TotalItemCount ?? 0;
}

<style>
    /* Chỉ dùng cho dynamic Razor conditions — không thể dùng Tailwind cho các class được tạo runtime */
    .cat-item-active {
        background: #fff7ed;
        color: #f97316;
        font-weight: 600;
    }

        .cat-item-active .cat-badge {
            background: #fed7aa;
            color: #f97316;
        }

    .cat-item-default {
        color: #374151;
    }

        .cat-item-default:hover {
            background: #f9fafb;
        }

    .star-on {
        color: #fbbf24;
    }

    .star-off {
        color: #e5e7eb;
    }
</style>

<div class="min-h-screen bg-gray-50">
    <div class="max-w-7xl mx-auto px-6 py-8 flex gap-6 items-start">

        <!-- ── SIDEBAR ── -->
        <aside class="w-52 shrink-0 sticky top-6 flex flex-col gap-3">

            <!-- Danh mục -->
            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-4">
                <p class="text-[10px] font-bold uppercase tracking-widest text-gray-400 mb-3">Danh mục</p>
                <ul class="flex flex-col gap-0.5">
                    <li>
                        <a asp-action="Index" asp-controller="Products"
                           asp-route-q="@currentQ" asp-route-sortBy="@currentSort"
                           class="flex items-center justify-between px-2.5 py-1.5 rounded-lg text-sm transition-colors @(currentCat==0 ? "cat-item-active" : "cat-item-default")">
                            <span>Tất cả</span>
                            <span class="cat-badge text-[10px] font-bold px-2 py-0.5 rounded-full bg-gray-100 text-gray-400">@totalCount</span>
                        </a>
                    </li>
                    @foreach (var cat in categories)
                    {
                        <li>
                            <a asp-action="Index" asp-controller="Products"
                               asp-route-categoryId="@cat.Id"
                               asp-route-q="@currentQ" asp-route-sortBy="@currentSort"
                               class="flex items-center justify-between px-2.5 py-1.5 rounded-lg text-sm transition-colors @(currentCat==cat.Id ? "cat-item-active" : "cat-item-default")">
                                <span>@cat.Name</span>
                            </a>
                        </li>
                    }
                </ul>
            </div>

            <!-- Khoảng giá -->
            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-4">
                <p class="text-[10px] font-bold uppercase tracking-widest text-gray-400 mb-3">Khoảng giá</p>
                <input type="range" min="0" max="100" value="50"
                       class="w-full h-1 rounded-full cursor-pointer accent-orange-500 mb-2" />
                <div class="flex justify-between text-[11px] font-semibold text-gray-400">
                    <span>0₫</span><span>50,000,000₫</span>
                </div>
            </div>

            <!-- Tình trạng -->
            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-4">
                <p class="text-[10px] font-bold uppercase tracking-widest text-gray-400 mb-3">Tình trạng</p>
                <div class="flex flex-wrap gap-1.5">
                    <a asp-action="Index" asp-controller="Products"
                       asp-route-categoryId="@currentCat" asp-route-q="@currentQ"
                       class="px-3 py-1 rounded-full text-xs font-semibold border border-gray-200 text-gray-600 hover:border-orange-400 hover:text-orange-500 transition-colors">
                        Tất cả
                    </a>
                    <a asp-action="Index" asp-controller="Products"
                       asp-route-categoryId="@currentCat" asp-route-q="@currentQ" asp-route-inStock="true"
                       class="px-3 py-1 rounded-full text-xs font-semibold border border-gray-200 text-gray-600 hover:border-orange-400 hover:text-orange-500 transition-colors">
                        Còn hàng
                    </a>
                    <a asp-action="Index" asp-controller="Products"
                       asp-route-categoryId="@currentCat" asp-route-q="@currentQ" asp-route-onSale="true"
                       class="px-3 py-1 rounded-full text-xs font-semibold bg-orange-500 border border-orange-500 text-white">
                        Giảm giá
                    </a>
                </div>
            </div>

            @if (currentCat > 0 || !string.IsNullOrEmpty(currentQ))
            {
                <a asp-action="Index" asp-controller="Products"
                   class="block text-center py-2 rounded-xl text-sm font-semibold text-orange-500 bg-orange-50 border border-orange-100 hover:bg-orange-500 hover:text-white transition-colors">
                    ✕ Xóa bộ lọc
                </a>
            }

        </aside>

        <!-- ── MAIN ── -->
        <div class="flex-1 min-w-0">

            <!-- Topbar -->
            <div class="flex items-center justify-between gap-3 mb-5 flex-wrap">
                <div class="flex items-center gap-3">
                    <p class="text-sm text-gray-500">
                        <strong class="text-gray-800 font-bold">@totalCount</strong> sản phẩm được tìm thấy
                    </p>
                    <form method="get" asp-action="Index" asp-controller="Products" class="relative">
                        @if (currentCat > 0)
                        {
                            <input type="hidden" name="categoryId" value="@currentCat" />
                        }
                        <span class="material-symbols-outlined absolute left-2.5 top-1/2 -translate-y-1/2 text-gray-300 pointer-events-none"
                              style="font-size:16px;">search</span>
                        <input type="text" name="q" value="@currentQ" placeholder="Tìm sản phẩm..."
                               class="h-9 w-52 pl-8 pr-3 rounded-xl border border-gray-200 bg-white text-sm text-gray-700 outline-none placeholder-gray-300
                          focus:border-orange-400 focus:ring-2 focus:ring-orange-100 transition" />
                    </form>
                </div>
                <div class="flex items-center gap-2">
                    <span class="text-sm text-gray-400">Sắp xếp:</span>
                    <form method="get" asp-action="Index" asp-controller="Products" id="sf">
                        @if (currentCat > 0)
                        {
                            <input type="hidden" name="categoryId" value="@currentCat" />
                        }
                        @if (!string.IsNullOrEmpty(currentQ))
                        {
                            <input type="hidden" name="q" value="@currentQ" />
                        }
                        <select name="sortBy" onchange="document.getElementById('sf').submit()"
                                class="h-9 pl-3 pr-8 rounded-xl border border-gray-200 bg-white text-sm font-medium text-gray-700
                           outline-none focus:border-orange-400 cursor-pointer transition"
                                style="appearance:none;background-image:url('data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%2210%22 height=%2210%22 viewBox=%220 0 24 24%22 fill=%22none%22 stroke=%22%239ca3af%22 stroke-width=%222.5%22%3E%3Cpath d=%22m6 9 6 6 6-6%22/%3E%3C/svg%3E');background-repeat:no-repeat;background-position:right 9px center;background-size:10px;">
                            <option value="" selected="@(currentSort==""          )">Mặc định</option>
                            <option value="price_asc" selected="@(currentSort=="price_asc" )">Giá thấp → cao</option>
                            <option value="price_desc" selected="@(currentSort=="price_desc")">Giá cao → thấp</option>
                            <option value="newest" selected="@(currentSort=="newest"    )">Mới nhất</option>
                            <option value="rating" selected="@(currentSort=="rating"    )">Đánh giá cao</option>
                        </select>
                    </form>
                </div>
            </div>

            <!-- Grid -->
            @if (Model != null && Model.Items.Any())
            {
                <div class="grid grid-cols-4 gap-4">
                    @foreach (var item in Model.Items)
                    {
                        <a asp-controller="Products" asp-action="Detail" asp-route-id="@item.Id"
                           class="group bg-white rounded-2xl border border-gray-100 overflow-hidden flex flex-col
                      shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-200 no-underline">

                            <!-- Ảnh -->
                            <div class="relative bg-gray-50 overflow-hidden" style="aspect-ratio:1">
                                @if (!string.IsNullOrEmpty(item.ThumbnailUrl))
                                {
                                    <img src="@item.ThumbnailUrl" alt="@item.Name" loading="lazy"
                                         class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
                                }
                                else
                                {
                                    <div class="absolute inset-0 flex items-center justify-center">
                                        <span class="material-symbols-outlined text-gray-200" style="font-size:48px;">image_not_supported</span>
                                    </div>
                                }

                                @if (item.Stock <= 0)
                                {
                                    <span class="absolute top-2.5 left-2.5 text-[10px] font-bold px-2.5 py-1 rounded-full bg-black/10 text-gray-500">Hết hàng</span>
                                }
                                else if (item.OriginalPrice.HasValue && item.OriginalPrice > item.Price)
                                {
                                    var d = (int)Math.Round((1 - (double)item.Price / (double)item.OriginalPrice.Value) * 100);
                                    <span class="absolute top-2.5 left-2.5 text-[10px] font-bold px-2.5 py-1 rounded-full bg-orange-500 text-white">-@d%</span>
                                }
                                else if (item.IsFeatured)
                                {
                                    <span class="absolute top-2.5 left-2.5 text-[10px] font-bold px-2.5 py-1 rounded-full bg-gray-900 text-white">Mới</span>
                                }
                            </div>

                            <!-- Thông tin -->
                            <div class="p-3.5 flex flex-col gap-1 flex-1">
                                @if (!string.IsNullOrEmpty(item.Brand))
                                {
                                    <p class="text-[10px] font-bold uppercase tracking-widest text-orange-500">@item.Brand</p>
                                }
                                <h4 class="text-sm font-semibold text-gray-800 leading-snug line-clamp-2">@item.Name</h4>

                                <div class="flex items-center gap-0.5 my-0.5">
                                    @for (int s = 1; s <= 5; s++)
                                    {
                                        <span class="@(s<=(int)Math.Round(item.Rating) ? "star-on" : "star-off")" style="font-size:11px;">★</span>
                                    }
                                    <span class="text-[10px] text-gray-300 ml-1">(@item.Rating.ToString("0.0"))</span>
                                </div>

                                <div class="flex items-end justify-between mt-auto pt-2.5 border-t border-gray-50">
                                    <div>
                                        <p class="text-[15px] font-bold text-orange-500">@item.Price.ToString("N0")₫</p>
                                        @if (item.OriginalPrice.HasValue && item.OriginalPrice > item.Price)
                                        {
                                            <p class="text-[11px] text-gray-300 line-through">@item.OriginalPrice.Value.ToString("N0")₫</p>
                                        }
                                    </div>
                                    <div class="w-8 h-8 rounded-lg bg-gray-50 border border-gray-100 flex items-center justify-center
                              text-gray-400 group-hover:bg-orange-500 group-hover:border-orange-500
                              group-hover:text-white transition-all shrink-0">
                                        <span class="material-symbols-outlined" style="font-size:14px;">shopping_cart</span>
                                    </div>
                                </div>
                            </div>

                        </a>
                    }
                </div>

                <!-- Pagination -->
                @if (Model.PageCount > 1)
                {
                    <div class="flex items-center justify-center gap-1.5 mt-10 flex-wrap">
                        @if (Model.HasPreviousPage)
                        {
                            <a asp-action="Index" asp-controller="Products"
                               asp-route-page="@(Model.CurrentPage-1)" asp-route-categoryId="@currentCat"
                               asp-route-q="@currentQ" asp-route-sortBy="@currentSort"
                               class="w-9 h-9 rounded-xl border border-gray-200 bg-white flex items-center justify-center
                        text-gray-500 hover:border-orange-400 hover:text-orange-500 transition-colors">
                                <span class="material-symbols-outlined" style="font-size:15px;">chevron_left</span>
                            </a>
                        }
                        else
                        {
                            <span class="w-9 h-9 rounded-xl border border-gray-100 bg-white flex items-center justify-center text-gray-200 pointer-events-none">
                                <span class="material-symbols-outlined" style="font-size:15px;">chevron_left</span>
                            </span>
                        }

                        @for (int p = 1; p <= Model.PageCount; p++)
                        {
                            if (p == Model.CurrentPage)
                            {
                                <span class="w-9 h-9 rounded-xl flex items-center justify-center text-sm font-bold text-white bg-orange-500">@p</span>
                            }
                            else if (p == 1 || p == Model.PageCount || Math.Abs(p - Model.CurrentPage) <= 2)
                            {
                                <a asp-action="Index" asp-controller="Products"
                                   asp-route-page="@p" asp-route-categoryId="@currentCat"
                                   asp-route-q="@currentQ" asp-route-sortBy="@currentSort"
                                   class="w-9 h-9 rounded-xl border border-gray-200 bg-white flex items-center justify-center
                          text-sm font-medium text-gray-600 hover:border-orange-400 hover:text-orange-500 transition-colors">@p</a>
                            }
                            else if (Math.Abs(p - Model.CurrentPage) == 3)
                            {
                                <span class="w-9 h-9 flex items-center justify-center text-sm text-gray-300">…</span>
                            }
                        }

                        @if (Model.HasNextPage)
                        {
                            <a asp-action="Index" asp-controller="Products"
                               asp-route-page="@(Model.CurrentPage+1)" asp-route-categoryId="@currentCat"
                               asp-route-q="@currentQ" asp-route-sortBy="@currentSort"
                               class="w-9 h-9 rounded-xl border border-gray-200 bg-white flex items-center justify-center
                        text-gray-500 hover:border-orange-400 hover:text-orange-500 transition-colors">
                                <span class="material-symbols-outlined" style="font-size:15px;">chevron_right</span>
                            </a>
                        }
                        else
                        {
                            <span class="w-9 h-9 rounded-xl border border-gray-100 bg-white flex items-center justify-center text-gray-200 pointer-events-none">
                                <span class="material-symbols-outlined" style="font-size:15px;">chevron_right</span>
                            </span>
                        }
                    </div>
                }
            }
            else
            {
                <div class="text-center py-24 text-gray-400">
                    <span class="material-symbols-outlined block text-gray-200 mb-3" style="font-size:48px;">inventory_2</span>
                    <p class="text-sm mb-4">Không tìm thấy sản phẩm nào.</p>
                    <a asp-action="Index" asp-controller="Products"
                       class="inline-flex items-center gap-1.5 px-5 py-2.5 rounded-xl bg-orange-500 text-white text-sm font-semibold hover:bg-orange-600 transition-colors">
                        Xem tất cả →
                    </a>
                </div>
            }

        </div>
    </div>
</div>
